@model List<ProjectSWD.DTOs.CartItemDTO>
@{
    ViewData["Title"] = "Checkout Order";
    var subtotal = Model.Sum(x => x.TotalPrice);
}

<!-- Google Fonts & Bootstrap Icons -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<!-- Custom Styles for Gia Hoa Phat E-Commerce Checkout -->
<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        --accent-color: #ff8c00;
        --accent-hover: #e07b00;
        --card-border-radius: 16px;
        --base-font-family: 'Plus Jakarta Sans', sans-serif;
        --bg-light-gray: #f8fafc;
        --text-dark: #0f172a;
        --text-muted: #64748b;
    }

    body {
        font-family: var(--base-font-family);
        background-color: var(--bg-light-gray);
        color: var(--text-dark);
    }

    .fw-bold-700 { font-weight: 700; }
    .fw-semibold-600 { font-weight: 600; }

    /* Progress Stepper styling */
    .checkout-stepper {
        display: flex;
        justify-content: space-between;
        position: relative;
        max-width: 600px;
        margin: 0 auto 2.5rem auto;
    }
    .checkout-stepper::before {
        content: "";
        position: absolute;
        top: 24px;
        left: 0;
        right: 0;
        height: 4px;
        background-color: #e2e8f0;
        z-index: 1;
    }
    .stepper-item {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        width: calc(100% / 3);
    }
    .stepper-circle {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background-color: #fff;
        border: 4px solid #e2e8f0;
        display: flex;
        justify-content: center;
        align-items: center;
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--text-muted);
        transition: all 0.3s ease;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }
    .stepper-item.active .stepper-circle {
        background: var(--primary-gradient);
        border-color: #fff;
        color: #fff;
        box-shadow: 0 10px 15px -3px rgba(30, 60, 114, 0.3);
    }
    .stepper-item.completed .stepper-circle {
        background-color: #10b981;
        border-color: #fff;
        color: #fff;
        box-shadow: 0 10px 15px -3px rgba(16, 185, 129, 0.3);
    }
    .stepper-text {
        margin-top: 0.5rem;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text-muted);
        transition: color 0.3s ease;
    }
    .stepper-item.active .stepper-text {
        color: #1e3c72;
    }

    /* Checkout Card styling */
    .checkout-card {
        border: none;
        border-radius: var(--card-border-radius);
        box-shadow: 0 4px 20px -2px rgba(15, 23, 42, 0.04);
        background-color: #ffffff;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .checkout-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px -5px rgba(15, 23, 42, 0.08);
    }
    .checkout-card-header {
        border-bottom: 1px solid #f1f5f9;
        background-color: #ffffff;
        border-top-left-radius: var(--card-border-radius) !important;
        border-top-right-radius: var(--card-border-radius) !important;
        padding: 1.25rem 1.5rem;
    }
    .card-title-icon {
        background: var(--primary-gradient);
        color: #fff;
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        margin-right: 0.75rem;
    }

    /* Interactive Payment Method Cards */
    .payment-card {
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        padding: 1.25rem;
        text-align: center;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        height: 100%;
        background-color: #fff;
        position: relative;
        overflow: hidden;
    }
    .payment-card:hover {
        border-color: #cbd5e1;
        transform: translateY(-2px);
    }
    .payment-card.active {
        border-color: #1e3c72;
        background-color: #f0f7ff;
        box-shadow: 0 4px 15px rgba(30, 60, 114, 0.08);
    }
    .payment-card-icon {
        font-size: 1.8rem;
        color: var(--text-muted);
        margin-bottom: 0.5rem;
        transition: color 0.25s ease;
    }
    .payment-card.active .payment-card-icon {
        color: #1e3c72;
    }
    .payment-card-title {
        font-weight: 700;
        font-size: 0.95rem;
        margin-bottom: 0.25rem;
        color: var(--text-dark);
    }
    .payment-card-desc {
        font-size: 0.75rem;
        color: var(--text-muted);
        line-height: 1.3;
    }
    .payment-card.active::after {
        content: "\f272";
        font-family: "bootstrap-icons";
        position: absolute;
        top: 8px;
        right: 8px;
        font-size: 1.1rem;
        color: #1e3c72;
        font-weight: 700;
    }

    /* Order Summary Sticky Card */
    .summary-card {
        border: none;
        border-radius: var(--card-border-radius);
        box-shadow: 0 10px 30px -10px rgba(30, 60, 114, 0.15);
        background: #ffffff;
        overflow: hidden;
    }
    .summary-header {
        background: var(--primary-gradient);
        color: #ffffff;
        padding: 1.5rem;
        border-bottom: none;
    }
    .btn-gradient {
        background: var(--primary-gradient);
        border: none;
        color: #ffffff;
        font-weight: 700;
        letter-spacing: 0.5px;
        padding: 0.85rem;
        border-radius: 10px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(30, 60, 114, 0.2);
    }
    .btn-gradient:hover {
        background: linear-gradient(135deg, #152b52 0%, #1e3c72 100%);
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(30, 60, 114, 0.3);
        color: #fff;
    }
    .btn-outline-gradient {
        border: 2px solid #1e3c72;
        background: transparent;
        color: #1e3c72;
        font-weight: 700;
        padding: 0.75rem 1.5rem;
        border-radius: 10px;
        transition: all 0.3s ease;
    }
    .btn-outline-gradient:hover {
        background: var(--primary-gradient);
        border-color: transparent;
        color: #ffffff;
    }

    /* Table styling tweaks */
    .product-table th {
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        color: var(--text-muted);
        border-bottom: 2px solid #f1f5f9;
        padding: 1rem 0.75rem;
    }
    .product-table td {
        padding: 1.25rem 0.75rem;
        border-bottom: 1px solid #f1f5f9;
    }

    /* Fullscreen Glassmorphic Loading Overlay */
    #loadingOverlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        z-index: 9999;
        display: flex;
        justify-content: center;
        align-items: center;
        transition: opacity 0.3s ease;
    }
    #loadingOverlay.d-none {
        display: none !important;
    }
    .spinner-box {
        background-color: #ffffff;
        padding: 2.5rem 3.5rem;
        border-radius: var(--card-border-radius);
        box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.2);
        max-width: 400px;
        text-align: center;
        border: 1px solid rgba(255, 255, 255, 0.8);
    }

    /* Success Page (Receipt Invoice card) styling */
    .invoice-card {
        border: none;
        border-radius: var(--card-border-radius);
        background: #ffffff;
        box-shadow: 0 20px 50px -15px rgba(0, 0, 0, 0.08);
        position: relative;
    }
    .invoice-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 8px;
        background: var(--primary-gradient);
        border-top-left-radius: var(--card-border-radius);
        border-top-right-radius: var(--card-border-radius);
    }
    .invoice-dash-line {
        border-top: 2px dashed #e2e8f0;
        margin: 2rem 0;
    }
    .success-badge-pulse {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background-color: #d1fae5;
        color: #10b981;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 2.2rem;
        margin: 0 auto 1.5rem auto;
        animation: pulse 2s infinite;
    }
    @@keyframes pulse {
        0% {
            box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4);
        }
        70% {
            box-shadow: 0 0 0 15px rgba(16, 185, 129, 0);
        }
        100% {
            box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
        }
    }
</style>

<!-- Loading Spinner Overlay -->
<div id="loadingOverlay" class="d-none">
    <div class="spinner-box">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Loading...</span>
        </div>
        <h5 class="text-dark fw-bold mt-4 mb-2">Đang Xử Lý</h5>
        <p class="text-muted small mb-0" id="loadingText">Vui lòng đợi trong giây lát khi chúng tôi hoàn tất đơn hàng...</p>
    </div>
</div>

<div class="container mt-4 mb-5">
    <!-- Title Page Header -->
    <div class="text-center mb-4">
        <h2 class="fw-bold-700 text-dark mb-1">Gia Hoa Phat System</h2>
        <p class="text-muted">Hoàn tất đặt hàng nhanh chóng, an toàn và tiện lợi</p>
    </div>

    <!-- Step Progress Indicator -->
    <div class="checkout-stepper">
        <div class="stepper-item completed">
            <div class="stepper-circle"><i class="bi bi-cart"></i></div>
            <div class="stepper-text">Giỏ Hàng</div>
        </div>
        <div class="stepper-item active" id="stepDelivery">
            <div class="stepper-circle"><i class="bi bi-truck"></i></div>
            <div class="stepper-text">Giao Hàng & Thanh Toán</div>
        </div>
        <div class="stepper-item" id="stepReceipt">
            <div class="stepper-circle"><i class="bi bi-receipt"></i></div>
            <div class="stepper-text">Hoàn Thành</div>
        </div>
    </div>

    <div class="row">
        <!-- Main Form & Cart Section -->
        <div id="checkoutMainSection" class="col-lg-8">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-left: 4px solid #10b981 !important;">
                    <i class="bi bi-check-circle-fill me-2 text-success"></i>
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <!-- Card 1: Order Products -->
            <div class="card checkout-card mb-4">
                <div class="card-header checkout-card-header d-flex align-items-center">
                    <span class="card-title-icon"><i class="bi bi-bag"></i></span>
                    <h5 class="mb-0 fw-bold-700 text-dark">1. Danh sách sản phẩm</h5>
                </div>
                <div class="card-body p-0">
                    @if (Model == null || !Model.Any())
                    {
                        <div class="text-center py-5 px-4">
                            <i class="bi bi-cart-x text-muted" style="font-size: 3.5rem;"></i>
                            <h5 class="text-muted mt-3 mb-3">Giỏ hàng của bạn đang trống!</h5>
                            <a href="/Customer/MyOrders/AddDummyDataToCart" class="btn btn-outline-gradient">
                                <i class="bi bi-plus-circle me-2"></i> Thêm sản phẩm mẫu thử nghiệm
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table align-middle product-table mb-0">
                                <thead>
                                    <tr>
                                        <th class="ps-4">Sản Phẩm</th>
                                        <th class="text-end">Đơn Giá</th>
                                        <th class="text-center">Số Lượng</th>
                                        <th class="text-end pe-4">Thành Tiền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="d-flex align-items-center">
                                                    <img src="@item.ProductImage" alt="@item.ProductName" class="img-thumbnail rounded me-3 shadow-sm" style="width: 60px; height: 60px; object-fit: cover;" onerror="this.src='https://placehold.co/60x60?text=Product';" />
                                                    <div>
                                                        <h6 class="mb-0 fw-semibold-600 text-dark">@item.ProductName</h6>
                                                        <span class="badge bg-light text-dark border small mt-1">Mã SP: #@item.ProductId</span>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-end fw-semibold">@item.Price.ToString("N0") đ</td>
                                            <td class="text-center">
                                                <span class="badge bg-secondary px-2.5 py-1.5 fw-bold" style="font-size: 0.9rem;">@item.Quantity.ToString("G29")</span>
                                            </td>
                                            <td class="text-end pe-4 fw-bold text-dark">@item.TotalPrice.ToString("N0") đ</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            @if (Model != null && Model.Any())
            {
                <!-- Card 2: Shipping Information -->
                <div class="card checkout-card mb-4">
                    <div class="card-header checkout-card-header d-flex align-items-center">
                        <span class="card-title-icon"><i class="bi bi-geo-alt"></i></span>
                        <h5 class="mb-0 fw-bold-700 text-dark">2. Thông tin giao hàng</h5>
                    </div>
                    <div class="card-body p-4">
                        <form id="checkoutForm" novalidate>
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <label for="fullName" class="form-label fw-semibold">Họ tên người nhận <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light"><i class="bi bi-person text-muted"></i></span>
                                        <input type="text" class="form-control py-2.5" id="fullName" required placeholder="Nhập họ và tên người nhận">
                                        <div class="invalid-feedback">Họ tên là trường bắt buộc.</div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label for="phoneNumber" class="form-label fw-semibold">Số điện thoại liên hệ <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light"><i class="bi bi-telephone text-muted"></i></span>
                                        <input type="tel" class="form-control py-2.5" id="phoneNumber" required placeholder="Nhập số điện thoại (ví dụ: 0912345678)">
                                        <div class="invalid-feedback">Số điện thoại hợp lệ là bắt buộc.</div>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <label for="address" class="form-label fw-semibold">Địa chỉ giao hàng <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light"><i class="bi bi-house-door text-muted"></i></span>
                                        <input type="text" class="form-control py-2.5" id="address" required placeholder="Ví dụ: 123 Nguyễn Huệ, Quận 1, TP. Hồ Chí Minh">
                                        <button type="button" class="btn btn-secondary px-4 fw-bold" id="btnCalculateShipping">Tính Phí Ship</button>
                                        <div class="invalid-feedback">Địa chỉ giao hàng là bắt buộc.</div>
                                    </div>
                                    <div class="form-text text-muted mt-2 small">
                                        <i class="bi bi-info-circle me-1"></i> Phí vận chuyển sẽ được ước tính tự động dựa trên độ dài của địa chỉ.
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Card 3: Payment Method -->
                <div class="card checkout-card mb-4">
                    <div class="card-header checkout-card-header d-flex align-items-center">
                        <span class="card-title-icon"><i class="bi bi-credit-card"></i></span>
                        <h5 class="mb-0 fw-bold-700 text-dark">3. Phương thức thanh toán</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <div class="payment-card active" onclick="selectPayment('COD', 'payCOD')">
                                    <div class="payment-card-icon">
                                        <i class="bi bi-cash-stack"></i>
                                    </div>
                                    <div class="payment-card-title">Giao hàng (COD)</div>
                                    <div class="payment-card-desc">Thanh toán bằng tiền mặt khi nhận hàng.</div>
                                    <input class="form-check-input d-none" type="radio" name="paymentMethod" id="payCOD" value="COD" checked>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="payment-card" onclick="selectPayment('CreditCard', 'payCredit')">
                                    <div class="payment-card-icon">
                                        <i class="bi bi-credit-card-2-front"></i>
                                    </div>
                                    <div class="payment-card-title">Thẻ Tín Dụng</div>
                                    <div class="payment-card-desc">Cổng thanh toán thẻ Visa/Mastercard (Mô phỏng 2s).</div>
                                    <input class="form-check-input d-none" type="radio" name="paymentMethod" id="payCredit" value="CreditCard">
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="payment-card" onclick="selectPayment('BankTransfer', 'payTransfer')">
                                    <div class="payment-card-icon">
                                        <i class="bi bi-bank"></i>
                                    </div>
                                    <div class="payment-card-title">Chuyển Khoản</div>
                                    <div class="payment-card-desc">Ứng dụng ngân hàng, Ví điện tử Momo, VNPAY.</div>
                                    <input class="form-check-input d-none" type="radio" name="paymentMethod" id="payTransfer" value="BankTransfer">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Sidebar Summary Section -->
        @if (Model != null && Model.Any())
        {
            <div id="checkoutSummarySection" class="col-lg-4">
                <div class="card summary-card sticky-top" style="top: 24px; z-index: 10;">
                    <div class="card-header summary-header">
                        <h5 class="mb-0 fw-bold-700 text-center uppercase tracking-wide"><i class="bi bi-receipt-cutoff me-2"></i>Tóm tắt đơn hàng</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Tổng tiền sản phẩm</span>
                            <span class="fw-semibold text-dark fs-6">@subtotal.ToString("N0") đ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3 align-items-center">
                            <span class="text-muted">Phí vận chuyển</span>
                            <span id="summaryShippingFee" class="text-danger fw-semibold"><i class="bi bi-exclamation-triangle me-1 small"></i>Chưa tính phí ship</span>
                        </div>
                        <hr class="my-3" style="border-top: 1px solid #e2e8f0;">
                        <div class="d-flex justify-content-between mb-4 align-items-baseline">
                            <span class="fs-5 fw-bold text-dark">Tổng thanh toán</span>
                            <span id="summaryTotal" class="fs-4 fw-bold text-primary">@subtotal.ToString("N0") đ</span>
                        </div>
                        
                        <div id="validationErrorMessage" class="alert alert-danger d-none mb-3 border-0 small shadow-sm" role="alert" style="border-left: 4px solid #ef4444 !important;"></div>

                        <button type="button" class="btn btn-gradient btn-lg w-100 py-3 fw-bold-700 text-uppercase" id="btnSubmitOrder">
                            Xác Nhận Đặt Hàng & Thanh Toán
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Success Receipt Container (Initially Hidden) -->
    <div id="successReceiptSection" class="row justify-content-center d-none mt-2">
        <div class="col-md-9 col-lg-8">
            <div class="card invoice-card shadow-lg">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <div class="success-badge-pulse">
                            <i class="bi bi-check-lg"></i>
                        </div>
                        <h3 class="text-success fw-bold-700 mb-2">ĐẶT HÀNG THÀNH CÔNG!</h3>
                        <p class="text-muted small">Cảm ơn bạn đã mua sắm tại Gia Hoa Phat System. Giao dịch của bạn đã được ghi nhận.</p>
                    </div>

                    <!-- Receipt Invoice Details Box -->
                    <div class="bg-light rounded-3 p-4 mb-4 border shadow-2xs">
                        <div class="row g-3">
                            <div class="col-sm-6">
                                <span class="text-muted d-block small fw-semibold">MÃ ĐƠN HÀNG</span>
                                <strong id="receiptOrderId" class="fs-5 text-primary">#ORD-0000</strong>
                            </div>
                            <div class="col-sm-6 text-sm-end">
                                <span class="text-muted d-block small fw-semibold">THỜI GIAN ĐẶT</span>
                                <strong id="receiptOrderDate" class="text-dark">--/--/---- --:--</strong>
                            </div>
                            
                            <div class="col-12 my-2"><hr class="my-1"></div>

                            <div class="col-sm-6">
                                <span class="text-muted d-block small fw-semibold">THÔNG TIN GIAO HÀNG</span>
                                <strong id="receiptFullName" class="text-dark">--</strong>
                                <span id="receiptPhone" class="d-block small text-muted">--</span>
                                <span id="receiptAddress" class="d-block small text-muted">--</span>
                            </div>
                            <div class="col-sm-6 text-sm-end">
                                <span class="text-muted d-block small fw-semibold">PHƯƠNG THỨC THANH TOÁN</span>
                                <strong id="receiptPaymentMethod" class="text-dark">--</strong>
                                <span class="d-block small text-success mt-1"><i class="bi bi-shield-check me-1"></i>Trạng thái: Đã hoàn tất</span>
                            </div>
                        </div>
                    </div>

                    <h5 class="fw-bold-700 mb-3 text-dark"><i class="bi bi-card-checklist me-2 text-primary"></i>Sản phẩm đã mua</h5>
                    <div class="table-responsive mb-4 border rounded">
                        <table class="table align-middle mb-0">
                            <thead class="table-light text-uppercase small">
                                <tr>
                                    <th class="ps-3" style="font-size: 0.75rem;">Tên Sản Phẩm</th>
                                    <th class="text-end" style="font-size: 0.75rem;">Đơn Giá</th>
                                    <th class="text-center" style="font-size: 0.75rem;">SL</th>
                                    <th class="text-end pe-3" style="font-size: 0.75rem;">Tổng</th>
                                </tr>
                            </thead>
                            <tbody id="receiptItemsBody">
                                <!-- Dynamic items row -->
                            </tbody>
                        </table>
                    </div>

                    <!-- Serrated Line Simulation -->
                    <div class="invoice-dash-line"></div>

                    <div class="row justify-content-end">
                        <div class="col-md-6 col-lg-5">
                            <div class="d-flex justify-content-between mb-2 small">
                                <span class="text-muted">Tiền hàng:</span>
                                <span id="receiptSubtotal" class="fw-semibold text-dark">0 đ</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2 small">
                                <span class="text-muted">Phí vận chuyển:</span>
                                <span id="receiptShippingFee" class="fw-semibold text-dark">0 đ</span>
                            </div>
                            <hr class="my-2">
                            <div class="d-flex justify-content-between align-items-baseline">
                                <span class="fs-6 fw-bold text-dark">Tổng thanh toán:</span>
                                <span id="receiptGrandTotal" class="fs-5 fw-bold text-primary">0 đ</span>
                            </div>
                        </div>
                    </div>

                    <div class="text-center mt-5">
                        <a href="/Customer/MyOrders/AddDummyDataToCart" class="btn btn-gradient px-4 me-2">Đặt đơn hàng khác</a>
                        <a href="/" class="btn btn-outline-secondary px-4 py-2">Quay lại Trang chủ</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // DOM Elements
            const addressInput = document.getElementById("address");
            const btnCalculateShipping = document.getElementById("btnCalculateShipping");
            const summaryShippingFee = document.getElementById("summaryShippingFee");
            const summaryTotal = document.getElementById("summaryTotal");
            const btnSubmitOrder = document.getElementById("btnSubmitOrder");
            const checkoutForm = document.getElementById("checkoutForm");
            const validationErrorMessage = document.getElementById("validationErrorMessage");
            
            // Overlays
            const loadingOverlay = document.getElementById("loadingOverlay");
            const loadingText = document.getElementById("loadingText");
            
            // Grid Panels
            const checkoutMainSection = document.getElementById("checkoutMainSection");
            const checkoutSummarySection = document.getElementById("checkoutSummarySection");
            const successReceiptSection = document.getElementById("successReceiptSection");

            // Receipt Elements
            const receiptOrderId = document.getElementById("receiptOrderId");
            const receiptOrderDate = document.getElementById("receiptOrderDate");
            const receiptFullName = document.getElementById("receiptFullName");
            const receiptPhone = document.getElementById("receiptPhone");
            const receiptAddress = document.getElementById("receiptAddress");
            const receiptPaymentMethod = document.getElementById("receiptPaymentMethod");
            const receiptItemsBody = document.getElementById("receiptItemsBody");
            const receiptSubtotal = document.getElementById("receiptSubtotal");
            const receiptShippingFee = document.getElementById("receiptShippingFee");
            const receiptGrandTotal = document.getElementById("receiptGrandTotal");

            // Cart Calculations Values
            const cartSubtotal = parseFloat("@subtotal");
            let calculatedShippingFee = 0;
            let hasCalculatedShipping = false;

            // Global Payment selection card toggle handler
            window.selectPayment = function(value, radioId) {
                // Set radio checked
                const radioBtn = document.getElementById(radioId);
                if (radioBtn) {
                    radioBtn.checked = true;
                }
                
                // Toggle active class visually
                document.querySelectorAll('.payment-card').forEach(card => {
                    card.classList.remove('active');
                });
                event.currentTarget.classList.add('active');
            }

            // Trigger Shipping Calculation on address blur (focusout) or click
            if (addressInput) {
                addressInput.addEventListener("blur", function () {
                    calculateShipping();
                });
                
                btnCalculateShipping.addEventListener("click", function () {
                    calculateShipping();
                });
            }

            function calculateShipping() {
                const addressVal = addressInput.value.trim();
                if (!addressVal) {
                    summaryShippingFee.innerHTML = '<i class="bi bi-exclamation-triangle me-1 small"></i>Chưa tính phí ship';
                    summaryShippingFee.className = "text-danger fw-semibold";
                    summaryTotal.innerText = formatCurrency(cartSubtotal) + " đ";
                    hasCalculatedShipping = false;
                    return;
                }

                // Show loading spinner for shipping fee calculation
                showLoading("Đang tính phí vận chuyển từ địa chỉ...");

                // Call AJAX calculate shipping fee
                fetch("/Customer/MyOrders/CalculateShipping", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({ address: addressVal })
                })
                .then(response => response.json())
                .then(data => {
                    hideLoading();
                    if (data.success) {
                        calculatedShippingFee = data.shippingFee;
                        hasCalculatedShipping = true;
                        summaryShippingFee.innerText = formatCurrency(calculatedShippingFee) + " đ";
                        summaryShippingFee.className = "fw-bold text-dark";
                        
                        const grandTotal = cartSubtotal + calculatedShippingFee;
                        summaryTotal.innerText = formatCurrency(grandTotal) + " đ";
                        validationErrorMessage.classList.add("d-none");
                    } else {
                        showError("Lỗi tính phí ship: " + data.message);
                    }
                })
                .catch(err => {
                    hideLoading();
                    showError("Đã có lỗi xảy ra khi tính toán phí vận chuyển. Vui lòng thử lại.");
                    console.error(err);
                });
            }

            // Submit Order on Click
            if (btnSubmitOrder) {
                btnSubmitOrder.addEventListener("click", function () {
                    // Check form validations
                    if (!checkoutForm.checkValidity()) {
                        checkoutForm.classList.add("was-validated");
                        showError("Vui lòng nhập đầy đủ họ tên, số điện thoại và địa chỉ nhận hàng.");
                        return;
                    }

                    if (!hasCalculatedShipping) {
                        showError("Vui lòng thực hiện tính phí vận chuyển trước khi xác nhận đơn hàng.");
                        return;
                    }

                    // Retrieve details
                    const fullName = document.getElementById("fullName").value.trim();
                    const phoneNumber = document.getElementById("phoneNumber").value.trim();
                    const address = addressInput.value.trim();
                    const selectedMethod = document.querySelector('input[name="paymentMethod"]:checked').value;

                    // Show Loading Spinner for Payment processing
                    showLoading("Đang kết nối cổng thanh toán... (Mô phỏng chờ cổng xử lý)");

                    // Submit Order AJAX Call
                    fetch("/Customer/MyOrders/SubmitOrder", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        },
                        body: JSON.stringify({
                            fullName: fullName,
                            phoneNumber: phoneNumber,
                            address: address,
                            paymentMethod: selectedMethod,
                            shippingFee: calculatedShippingFee
                        })
                    })
                    .then(response => response.json())
                    .then(data => {
                        hideLoading();
                        if (data.success) {
                            // Update stepper state
                            document.getElementById("stepDelivery").classList.remove("active");
                            document.getElementById("stepDelivery").classList.add("completed");
                            document.getElementById("stepReceipt").classList.add("active");
                            
                            // Display Receipt page
                            showReceipt(data.data);
                        } else {
                            showError("Thanh toán & đặt hàng thất bại: " + data.message);
                        }
                    })
                    .catch(err => {
                        hideLoading();
                        showError("Đã xảy ra sự cố kết nối hệ thống. Vui lòng thanh toán lại.");
                        console.error(err);
                    });
                });
            }

            // Utilities
            function showLoading(text) {
                loadingText.innerText = text;
                loadingOverlay.classList.remove("d-none");
            }

            function hideLoading() {
                loadingOverlay.classList.add("d-none");
            }

            function showError(msg) {
                validationErrorMessage.innerText = msg;
                validationErrorMessage.classList.remove("d-none");
                validationErrorMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }

            function formatCurrency(value) {
                return new Intl.NumberFormat('vi-VN').format(value);
            }

            function showReceipt(orderSummary) {
                // Populate receipt text fields
                receiptOrderId.innerText = "#ORD-" + orderSummary.orderId;
                receiptOrderDate.innerText = formatDate(orderSummary.orderTime);
                receiptFullName.innerText = orderSummary.fullName;
                receiptPhone.innerText = "Điện thoại: " + orderSummary.phoneNumber;
                receiptAddress.innerText = "Địa chỉ nhận: " + orderSummary.address;
                
                let payMethodName = "Giao hàng thu tiền (COD)";
                if (orderSummary.paymentMethod === "CreditCard") {
                    payMethodName = "Thẻ Tín Dụng (Visa/Mastercard)";
                } else if (orderSummary.paymentMethod === "BankTransfer") {
                    payMethodName = "Chuyển khoản / Ví điện tử";
                }
                receiptPaymentMethod.innerText = payMethodName;

                // Populate receipt items list
                receiptItemsBody.innerHTML = "";
                orderSummary.items.forEach(item => {
                    const row = `
                        <tr>
                            <td class="ps-3">
                                <div class="fw-semibold-600 text-dark">${item.productName}</div>
                                <span class="text-muted small" style="font-size: 0.75rem;">Mã SP: #${item.productId}</span>
                            </td>
                            <td class="text-end">${formatCurrency(item.price)} đ</td>
                            <td class="text-center font-monospace">${item.quantity}</td>
                            <td class="text-end pe-3 fw-bold text-dark">${formatCurrency(item.totalPrice)} đ</td>
                        </tr>
                    `;
                    receiptItemsBody.insertAdjacentHTML('beforeend', row);
                });

                // Set totals
                receiptSubtotal.innerText = formatCurrency(orderSummary.productTotal) + " đ";
                receiptShippingFee.innerText = formatCurrency(orderSummary.shippingFee) + " đ";
                receiptGrandTotal.innerText = formatCurrency(orderSummary.totalPrice) + " đ";

                // Swap displays
                checkoutMainSection.classList.add("d-none");
                if (checkoutSummarySection) {
                    checkoutSummarySection.classList.add("d-none");
                }
                successReceiptSection.classList.remove("d-none");
                successReceiptSection.scrollIntoView({ behavior: 'smooth' });
            }

            function formatDate(dateStr) {
                const date = new Date(dateStr);
                const day = String(date.getDate()).padStart(2, '0');
                const month = String(date.getMonth() + 1).padStart(2, '0');
                const year = date.getFullYear();
                const hours = String(date.getHours()).padStart(2, '0');
                const minutes = String(date.getMinutes()).padStart(2, '0');
                return `${day}/${month}/${year} ${hours}:${minutes}`;
            }
        });
    </script>
}
