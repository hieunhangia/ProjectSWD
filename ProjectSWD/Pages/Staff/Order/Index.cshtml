@page
@model ProjectSWD.Pages.Staff.Order.IndexModel
@using ProjectSWD.Data.Enums
@{
    ViewData["Title"] = "Quản lý Đơn Hàng";
    var currentStatus = Model.StatusFilter ?? "All";
}

<!-- Custom Styles for Premium Look -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    body {
        background-color: #f8f9fa;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }
    
    .dashboard-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        background: #ffffff;
    }

    .status-tab {
        border-radius: 30px;
        padding: 8px 20px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.2s ease;
        margin-right: 8px;
        margin-bottom: 8px;
        color: #6c757d;
        background: #f1f3f5;
        border: 1px solid transparent;
        display: inline-flex;
        align-items: center;
        text-decoration: none;
    }

    .status-tab:hover {
        background: #e9ecef;
        color: #495057;
    }

    .status-tab.active {
        background: #0d6efd;
        color: #ffffff;
        box-shadow: 0 4px 10px rgba(13, 110, 253, 0.2);
    }

    .table-responsive {
        border-radius: 12px;
        overflow: hidden;
    }

    .table {
        margin-bottom: 0;
    }

    .table th {
        background-color: #f1f3f5;
        color: #495057;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        padding: 16px;
        border-bottom: none;
    }

    .table td {
        padding: 16px;
        vertical-align: middle;
        font-size: 0.9rem;
        border-bottom: 1px solid #f1f3f5;
    }

    .table tr:last-child td {
        border-bottom: none;
    }

    .badge-status {
        padding: 6px 12px;
        border-radius: 30px;
        font-weight: 600;
        font-size: 0.75rem;
    }

    .search-input {
        border-radius: 30px;
        padding-left: 20px;
        border: 1px solid #ced4da;
    }

    .search-btn {
        border-radius: 30px;
        padding-left: 24px;
        padding-right: 24px;
    }

    .btn-action {
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 600;
        padding: 6px 12px;
        transition: all 0.2s ease;
    }

    .btn-action:hover {
        transform: translateY(-1px);
    }
</style>

<div class="container py-4">
    <!-- Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4 border-0 shadow-sm" role="alert" style="border-radius: 12px;">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4 border-0 shadow-sm" role="alert" style="border-radius: 12px;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Quản lý Đơn Hàng</h2>
            <p class="text-muted mb-0">Xem và xử lý các đơn hàng của khách hàng hệ thống.</p>
        </div>
    </div>

    <!-- Search and Filters Section -->
    <div class="card dashboard-card p-4 mb-4">
        <form method="get" class="row g-3 align-items-center">
            <input type="hidden" name="StatusFilter" value="@currentStatus" />
            <div class="col-lg-8">
                <div class="input-group shadow-sm" style="border-radius: 30px; overflow: hidden;">
                    <span class="input-group-text bg-white border-end-0 ps-3">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text" asp-for="SearchTerm" class="form-control border-start-0 py-2 ps-2 search-input" placeholder="Tìm theo Mã đơn, Tên khách hàng hoặc Số điện thoại..." />
                </div>
            </div>
            <div class="col-lg-4 d-grid">
                <button type="submit" class="btn btn-primary search-btn py-2 shadow-sm">
                    <i class="bi bi-funnel me-1"></i> Tìm kiếm & Lọc
                </button>
            </div>
        </form>

        <hr class="my-4 text-muted opacity-25">

        <!-- Status Filter Tabs -->
        <div class="d-flex flex-wrap">
            <a href="?StatusFilter=All&SearchTerm=@Model.SearchTerm" class="status-tab @(currentStatus == "All" ? "active" : "")">
                <i class="bi bi-grid me-2"></i> Tất cả
            </a>
            <a href="?StatusFilter=AwaitingConfirmation&SearchTerm=@Model.SearchTerm" class="status-tab @(currentStatus == "AwaitingConfirmation" ? "active" : "")">
                <i class="bi bi-hourglass-split me-2"></i> Chờ Xác Nhận
            </a>
            <a href="?StatusFilter=Confirmed&SearchTerm=@Model.SearchTerm" class="status-tab @(currentStatus == "Confirmed" ? "active" : "")">
                <i class="bi bi-check-circle me-2"></i> Đã Xác Nhận
            </a>
            <a href="?StatusFilter=InTransit&SearchTerm=@Model.SearchTerm" class="status-tab @(currentStatus == "InTransit" ? "active" : "")">
                <i class="bi bi-truck me-2"></i> Đang Giao
            </a>
            <a href="?StatusFilter=Delivered&SearchTerm=@Model.SearchTerm" class="status-tab @(currentStatus == "Delivered" ? "active" : "")">
                <i class="bi bi-house-check me-2"></i> Đã Giao
            </a>
            <a href="?StatusFilter=Cancelled&SearchTerm=@Model.SearchTerm" class="status-tab @(currentStatus == "Cancelled" ? "active" : "")">
                <i class="bi bi-x-circle me-2"></i> Đã Hủy
            </a>
        </div>
    </div>

    <!-- Orders Table -->
    <div class="card dashboard-card">
        <div class="card-body p-0">
            @if (Model.Orders == null || Model.Orders.Count == 0)
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                    <p class="mt-3 text-muted fw-semibold">Không tìm thấy đơn hàng nào khớp với bộ lọc.</p>
                    <a href="/Staff/Order" class="btn btn-outline-primary btn-sm mt-2" style="border-radius: 20px;">Xóa bộ lọc</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th class="ps-4">Mã Đơn</th>
                                <th>Khách Hàng</th>
                                <th>Số Điện Thoại</th>
                                <th>Ngày Đặt</th>
                                <th>Tổng Tiền</th>
                                <th>Trạng Thái</th>
                                <th>Nhân Viên</th>
                                <th class="text-end pe-4">Hành Động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.Orders)
                            {
                                <tr>
                                    <td class="fw-bold text-dark ps-4">#ORD-@order.Id</td>
                                    <td>
                                        <div class="fw-semibold">@order.FullName</div>
                                    </td>
                                    <td>@order.PhoneNumber</td>
                                    <td>
                                        <div class="text-muted" style="font-size: 0.85rem;">
                                            @order.Time.ToString("dd/MM/yyyy")
                                        </div>
                                        <div class="text-muted-small" style="font-size: 0.75rem; color: #a0a0a0;">
                                            @order.Time.ToString("HH:mm")
                                        </div>
                                    </td>
                                    <td class="fw-bold text-primary">@order.TotalPrice.ToString("N0") đ</td>
                                    <td>
                                        @switch (order.Status)
                                        {
                                            case OrderStatus.AwaitingConfirmation:
                                                <span class="badge bg-warning-subtle text-warning badge-status">Chờ Xác Nhận</span>
                                                break;
                                            case OrderStatus.Confirmed:
                                                <span class="badge bg-primary-subtle text-primary badge-status">Đã Xác Nhận</span>
                                                break;
                                            case OrderStatus.InTransit:
                                                <span class="badge bg-info-subtle text-info badge-status">Đang Giao</span>
                                                break;
                                            case OrderStatus.Delivered:
                                                <span class="badge bg-success-subtle text-success badge-status">Đã Giao</span>
                                                break;
                                            case OrderStatus.Cancelled:
                                                <span class="badge bg-danger-subtle text-danger badge-status">Đã Hủy</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @if (order.Staff != null)
                                        {
                                            <span class="text-muted" style="font-size: 0.85rem;"><i class="bi bi-person me-1"></i>@order.Staff.FullName</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted-small" style="font-size: 0.85rem; color: #b0b0b0;">-</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="d-flex gap-1 justify-content-end">
                                            <a href="/Staff/Order/Details?id=@order.Id" class="btn btn-outline-secondary btn-action" title="Xem Chi Tiết">
                                                <i class="bi bi-eye"></i> Chi tiết
                                            </a>

                                            @if (order.Status == OrderStatus.AwaitingConfirmation)
                                            {
                                                <form method="post" asp-page-handler="Confirm" asp-route-id="@order.Id" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn XÁC NHẬN đơn hàng #ORD-@order.Id không?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-success btn-action" title="Xác nhận">
                                                        <i class="bi bi-check-lg"></i>
                                                    </button>
                                                </form>

                                                <form method="post" asp-page-handler="Cancel" asp-route-id="@order.Id" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn HỦY đơn hàng #ORD-@order.Id không? Thao tác này sẽ hoàn trả số lượng sản phẩm lại kho hàng.');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-danger btn-action" title="Hủy">
                                                        <i class="bi bi-x-lg"></i>
                                                    </button>
                                                </form>
                                            }
                                            else if (order.Status == OrderStatus.Confirmed)
                                            {
                                                <form method="post" asp-page-handler="Ship" asp-route-id="@order.Id" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-info text-dark btn-action" title="Giao hàng">
                                                        <i class="bi bi-truck"></i> Giao
                                                    </button>
                                                </form>
                                            }
                                            else if (order.Status == OrderStatus.InTransit)
                                            {
                                                <form method="post" asp-page-handler="Complete" asp-route-id="@order.Id" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-primary btn-action" title="Hoàn thành">
                                                        <i class="bi bi-check-all"></i> Xong
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
