@page
@model ProjectSWD.Pages.Staff.Product.IndexModel
@{
    ViewData["Title"] = "Quản lý Sản phẩm";
}

<div class="container mt-4">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">@ViewData["Title"]</h2>
            <p class="text-muted mb-0">Quản lý và theo dõi thông tin hàng hóa, tồn kho sản phẩm</p>
        </div>
        <a href="/Staff/Product/ConfigProduct" class="btn btn-primary px-4 py-2 shadow-sm rounded-pill">
            <i class="bi bi-plus-circle-fill me-2"></i> Thêm sản phẩm mới
        </a>
    </div>

    <!-- Notifications -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Search and Filters -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-3">
            <form method="get" class="row g-3 align-items-center">
                <!-- Search term -->
                <div class="col-md-5">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text" name="SearchTerm" class="form-control border-start-0 ps-0" 
                               placeholder="Tìm kiếm theo tên sản phẩm..." value="@Model.SearchTerm" />
                    </div>
                </div>

                <!-- Category filter -->
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-tag text-muted"></i>
                        </span>
                        <select name="CategoryId" class="form-select border-start-0 ps-0" asp-for="CategoryId">
                            <option value="">-- Tất cả danh mục --</option>
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                    </div>
                </div>

                <!-- Action buttons -->
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4 w-100">Tìm kiếm</button>
                    @if (!string.IsNullOrEmpty(Model.SearchTerm) || Model.CategoryId.HasValue)
                    {
                        <a href="/Staff/Product/Index" class="btn btn-outline-secondary px-3" title="Đặt lại bộ lọc">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </a>
                    }
                </div>
            </form>
        </div>
    </div>

    <!-- Products Table -->
    @if (!Model.Products.Any())
    {
        <div class="card border-0 shadow-sm text-center py-5">
            <div class="card-body">
                <i class="bi bi-box-seam text-muted" style="font-size: 3rem;"></i>
                <h5 class="text-secondary fw-semibold mt-3">Không tìm thấy sản phẩm nào</h5>
                @if (!string.IsNullOrEmpty(Model.SearchTerm) || Model.CategoryId.HasValue)
                {
                    <p class="text-muted">Thử thay đổi từ khóa hoặc bộ lọc danh mục.</p>
                    <a href="/Staff/Product/Index" class="btn btn-outline-primary rounded-pill px-4 mt-2">Xem tất cả sản phẩm</a>
                }
                else
                {
                    <p class="text-muted">Hệ thống chưa có sản phẩm nào.</p>
                    <a href="/Staff/Product/ConfigProduct" class="btn btn-primary rounded-pill px-4 mt-2">Tạo sản phẩm đầu tiên</a>
                }
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light border-bottom text-secondary">
                        <tr>
                            <th class="ps-4 py-3" style="width: 80px;">Hình ảnh</th>
                            <th class="py-3">Tên sản phẩm</th>
                            <th class="py-3">Danh mục</th>
                            <th class="py-3 text-end">Giá bán</th>
                            <th class="py-3 text-center">Tồn kho</th>
                            <th class="pe-4 py-3 text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var prod in Model.Products)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="product-img-container bg-light rounded border overflow-hidden">
                                        @if (!string.IsNullOrEmpty(prod.ImageUrl))
                                        {
                                            <img src="@prod.ImageUrl" alt="@prod.Name" class="product-img" />
                                        }
                                        else
                                        {
                                            <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                                                <i class="bi bi-image" style="font-size: 1.2rem;"></i>
                                            </div>
                                        }
                                    </div>
                                </td>
                                <td class="py-3">
                                    <span class="fw-semibold text-dark d-block">@prod.Name</span>
                                    <small class="text-muted">ID: @prod.Id</small>
                                </td>
                                <td class="py-3">
                                    <span class="badge bg-secondary-soft text-secondary rounded-pill px-3 py-1 fw-medium">
                                        @(prod.Category?.Name ?? "Chưa phân loại")
                                    </span>
                                </td>
                                <td class="py-3 text-end fw-bold text-primary">
                                    @prod.Price.ToString("N0")₫
                                </td>
                                <td class="py-3 text-center">
                                    <div class="d-inline-block">
                                        <span class="fw-semibold @(prod.Quantity <= 5 ? "text-danger" : "text-dark")">
                                            @prod.Quantity
                                        </span>
                                        <small class="text-muted">@(prod.Unit?.Name ?? "")</small>
                                    </div>
                                    @if (prod.Quantity <= 5)
                                    {
                                        <span class="d-block text-danger small-alert"><i class="bi bi-exclamation-triangle-fill"></i> Sắp hết hàng</span>
                                    }
                                </td>
                                <td class="pe-4 py-3 text-end">
                                    <div class="btn-group">
                                        <a href="/Staff/Product/ConfigProduct/@prod.Id" class="btn btn-sm btn-outline-primary me-2 rounded" title="Chỉnh sửa">
                                            <i class="bi bi-pencil-square"></i> Sửa
                                        </a>
                                        <button type="button" class="btn btn-sm btn-outline-danger rounded" title="Xóa"
                                                data-bs-toggle="modal" data-bs-target="#deleteProductModal"
                                                data-id="@prod.Id" data-name="@prod.Name">
                                            <i class="bi bi-trash"></i> Xóa
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteProductModal" tabindex="-1" aria-labelledby="deleteProductModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-danger" id="deleteProductModalLabel">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> Xác nhận xóa sản phẩm
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4">
                <p class="text-dark">Bạn có chắc chắn muốn xóa sản phẩm sau đây?</p>
                <div class="bg-light p-3 rounded mb-3 border text-center">
                    <strong id="deleteProductName" class="text-dark fs-5"></strong>
                </div>
                <div class="alert alert-warning mb-0 border-0 shadow-sm py-2">
                    <small><i class="bi bi-info-circle-fill me-1"></i> Việc xóa sản phẩm chỉ thực hiện được nếu sản phẩm chưa tồn tại trong lịch sử đơn hàng hoặc các yêu cầu hoàn tiền nào.</small>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy bỏ</button>
                <form method="post" asp-page-handler="Delete">
                    <input type="hidden" name="id" id="deleteProductId" />
                    <button type="submit" class="btn btn-danger rounded-pill px-4">Đồng ý xóa</button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .product-img-container {
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .product-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .bg-secondary-soft {
        background-color: rgba(108, 117, 125, 0.1);
    }
    .small-alert {
        font-size: 0.75rem;
        margin-top: 2px;
    }
    .btn-group .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
    }
</style>

@section Scripts {
    <script>
        const deleteProductModal = document.getElementById('deleteProductModal');
        if (deleteProductModal) {
            deleteProductModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                const id = button.getAttribute('data-id');
                const name = button.getAttribute('data-name');
                
                document.getElementById('deleteProductId').value = id;
                document.getElementById('deleteProductName').textContent = name;
            });
        }
    </script>
}
