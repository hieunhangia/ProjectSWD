@page
@model IndexModel
@{
    ViewData["Title"] = "Trang chủ";

    string PageUrl(int page)
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(Model.SearchTerm)) { parts.Add($"SearchTerm={Uri.EscapeDataString(Model.SearchTerm)}"); }
        if (Model.CategoryId.HasValue) { parts.Add($"CategoryId={Model.CategoryId.Value}"); }
        if (!string.IsNullOrEmpty(Model.Sort)) { parts.Add($"Sort={Uri.EscapeDataString(Model.Sort)}"); }
        if (Model.MinPrice.HasValue) { parts.Add($"MinPrice={Model.MinPrice.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)}"); }
        if (Model.MaxPrice.HasValue) { parts.Add($"MaxPrice={Model.MaxPrice.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)}"); }
        if (Model.MinRating.HasValue) { parts.Add($"MinRating={Model.MinRating.Value}"); }
        parts.Add($"PageNumber={page}");
        return "/?" + string.Join("&", parts);
    }
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Hero banner -->
<div class="p-5 mb-4 rounded-3 text-white" style="background: linear-gradient(135deg, #8B5E3C 0%, #C4956A 100%);">
    <div class="container-fluid py-3">
        <h1 class="display-8 fw-bold">Hệ thống đặt hàng nguyên liệu làm bánh Gia Hoa Phát</h1>
        <p class="col-md-8 fs-5 mb-0">
            Nguyên liệu &amp; dụng cụ làm bánh chất lượng — bột, đường, bơ, chocolate và hơn thế nữa.
            Giao hàng nhanh toàn quốc!
        </p>
    </div>
</div>

@if (Model.LoadError != null)
{
    <div class="alert alert-danger" role="alert">
        @Model.LoadError
    </div>
    return;
}

<!-- Search & filter -->
<form method="get" class="row g-2 mb-4 align-items-end">
    <div class="col-md-4">
        <label class="form-label mb-1">Tìm kiếm sản phẩm</label>
        <input type="text" class="form-control" name="SearchTerm" value="@Model.SearchTerm"
               placeholder="Ví dụ: bột mì, chocolate, khuôn bánh..." />
    </div>
    <div class="col-md-2">
        <label class="form-label mb-1">Danh mục</label>
        <select class="form-select" name="CategoryId">
            <option value="">Tất cả danh mục</option>
            @foreach (var cat in Model.Categories)
            {
                <option value="@cat.Id" selected="@(Model.CategoryId == cat.Id)">@cat.Name</option>
            }
        </select>
    </div>
    <div class="col-md-2 col-6">
        <label class="form-label mb-1">Giá từ (đ)</label>
        <input type="number" class="form-control" name="MinPrice" value="@Model.MinPrice"
               min="0" step="1000" placeholder="0" />
    </div>
    <div class="col-md-2 col-6">
        <label class="form-label mb-1">Giá đến (đ)</label>
        <input type="number" class="form-control" name="MaxPrice" value="@Model.MaxPrice"
               min="0" step="1000" placeholder="Không giới hạn" />
    </div>
    <div class="col-md-2">
        <label class="form-label mb-1">Đánh giá</label>
        <select class="form-select" name="MinRating">
            <option value="">Tất cả đánh giá</option>
            @for (var star = 1; star <= 5; star++)
            {
                <option value="@star" selected="@(Model.MinRating == star)">Từ @(star)★ trở lên</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label mb-1">Sắp xếp</label>
        <select class="form-select" name="Sort">
            <option value="" selected="@(string.IsNullOrEmpty(Model.Sort))">Tên A → Z</option>
            <option value="name_desc" selected="@(Model.Sort == "name_desc")">Tên Z → A</option>
            <option value="price_asc" selected="@(Model.Sort == "price_asc")">Giá thấp → cao</option>
            <option value="price_desc" selected="@(Model.Sort == "price_desc")">Giá cao → thấp</option>
            <option value="best_seller" selected="@(Model.Sort == "best_seller")">Bán chạy nhất</option>
        </select>
    </div>
    <div class="col-md-2 d-grid">
        <button type="submit" class="btn btn-primary">Lọc</button>
    </div>
</form>

<!-- Category quick chips -->
<div class="mb-4 d-flex flex-wrap gap-2">
    <a href="/" class="btn btn-sm @(Model.CategoryId == null ? "btn-dark" : "btn-outline-dark")">Tất cả</a>
    @foreach (var cat in Model.Categories)
    {
        <a href="/?CategoryId=@cat.Id"
           class="btn btn-sm @(Model.CategoryId == cat.Id ? "btn-dark" : "btn-outline-dark")">@cat.Name</a>
    }
</div>

@if (Model.Products.Count == 0)
{
    <div class="text-center text-muted py-5">
        <h4>Không tìm thấy sản phẩm nào 😥</h4>
        <p>Hãy thử từ khóa khác hoặc chọn danh mục khác.</p>
    </div>

    @if (Model.TrendingProducts.Count > 0)
    {
        <h5 class="mb-3">🔥 Sản phẩm bán chạy</h5>
        <div class="row row-cols-2 row-cols-md-4 g-3 mb-4">
            @foreach (var product in Model.TrendingProducts)
            {
                <div class="col">
                    <a href="/Product/@product.Id" class="text-decoration-none text-dark">
                        <div class="card h-100 shadow-sm">
                            <img src="@product.ImageUrl" class="card-img-top bg-light" alt="@product.Name"
                                 style="height: 120px; object-fit: cover;"
                                 onerror="this.onerror=null;this.src='data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22300%22 height=%22180%22><rect width=%22100%25%22 height=%22100%25%22 fill=%22%23f3ede4%22/><text x=%2250%25%22 y=%2250%25%22 font-size=%2248%22 text-anchor=%22middle%22 dominant-baseline=%22middle%22>🧁</text></svg>';" />
                            <div class="card-body p-2">
                                <h6 class="card-title small mb-1" title="@product.Name">@product.Name</h6>
                                <span class="fw-bold">@product.Price.ToString("N0")đ</span>
                                <small class="text-muted">/ @product.Unit?.Name</small>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
}
else
{
    <p class="text-muted">
        Hiển thị <strong>@Model.ShowingFrom–@Model.ShowingTo</strong> trong tổng <strong>@Model.TotalCount</strong> sản phẩm
    </p>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var product in Model.Products)
        {
            var hasDiscount = Model.ActiveDiscounts.TryGetValue(product.Id, out var percent);
            var salePrice = hasDiscount ? Math.Round(product.Price * (1 - percent / 100m), 0) : product.Price;
            var outOfStock = product.Quantity <= 0;
            var hasRating = Model.Ratings.TryGetValue(product.Id, out var rating);
            var filledStars = hasRating ? (int)Math.Round(rating.Avg) : 0;

            <div class="col">
                <div class="card h-100 shadow-sm position-relative">
                    @if (hasDiscount)
                    {
                        <span class="badge bg-danger position-absolute top-0 start-0 m-2" style="z-index: 1;">
                            -@percent.ToString("0")%
                        </span>
                    }
                    @if (outOfStock)
                    {
                        <span class="badge bg-secondary position-absolute top-0 end-0 m-2" style="z-index: 1;">
                            Hết hàng
                        </span>
                    }

                    <a href="/Product/@product.Id">
                        <img src="@product.ImageUrl" class="card-img-top bg-light" alt="@product.Name"
                             style="height: 180px; object-fit: cover;"
                             onerror="this.onerror=null;this.src='data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22300%22 height=%22180%22><rect width=%22100%25%22 height=%22100%25%22 fill=%22%23f3ede4%22/><text x=%2250%25%22 y=%2250%25%22 font-size=%2248%22 text-anchor=%22middle%22 dominant-baseline=%22middle%22>🧁</text></svg>';" />
                    </a>

                    <div class="card-body d-flex flex-column">
                        <span class="badge bg-light text-dark border align-self-start mb-2">@product.Category?.Name</span>
                        <h6 class="card-title" title="@product.Name">
                            <a href="/Product/@product.Id" class="text-decoration-none text-dark">@product.Name</a>
                        </h6>

                        @if (hasRating)
                        {
                            <div class="small mb-1">
                                <span class="text-warning">@(new string('★', filledStars))@(new string('☆', 5 - filledStars))</span>
                                <span class="text-muted">@rating.Avg.ToString("0.#") (@rating.Count)</span>
                            </div>
                        }
                        else
                        {
                            <div class="small text-muted mb-1">Chưa có đánh giá</div>
                        }

                        <div class="mt-auto">
                            <div class="mb-2">
                                @if (hasDiscount)
                                {
                                    <span class="fw-bold text-danger fs-5">@salePrice.ToString("N0")đ</span>
                                    <span class="text-muted text-decoration-line-through ms-1">@product.Price.ToString("N0")đ</span>
                                }
                                else
                                {
                                    <span class="fw-bold fs-5">@product.Price.ToString("N0")đ</span>
                                }
                                <small class="text-muted">/ @product.Unit?.Name</small>
                            </div>
                            <small class="text-muted d-block mb-2">Còn lại: @product.Quantity.ToString("0.##") @product.Unit?.Name</small>

                            <form method="post" action="/Cart/AddToCart" class="d-flex gap-2">
                                <input type="hidden" name="productId" value="@product.Id" />
                                <input type="number" name="quantity" value="1"
                                       min="@(product.Unit?.AllowsDecimal == true ? "0.1" : "1")"
                                       step="@(product.Unit?.AllowsDecimal == true ? "0.1" : "1")"
                                       max="@product.Quantity"
                                       class="form-control form-control-sm" style="width: 70px;"
                                       @(outOfStock ? "disabled" : "") />
                                <button type="submit" class="btn btn-sm btn-primary flex-grow-1" @(outOfStock ? "disabled" : "")>
                                    🛒 Thêm vào giỏ
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Phân trang sản phẩm" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                    <a class="page-link" href="@PageUrl(Model.PageNumber - 1)">Trước</a>
                </li>
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link" href="@PageUrl(i)">@i</a>
                    </li>
                }
                <li class="page-item @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" href="@PageUrl(Model.PageNumber + 1)">Sau</a>
                </li>
            </ul>
        </nav>
    }
}
