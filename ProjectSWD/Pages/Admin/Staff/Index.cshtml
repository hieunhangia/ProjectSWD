@page
@model ProjectSWD.Pages.Admin.Staff.IndexModel
@{
    ViewData["Title"] = "Quản lý Nhân Viên";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">@ViewData["Title"]</h2>
        <a href="/Admin/Staff/ConfigStaff" class="btn btn-primary px-4 py-2 shadow-sm rounded-pill">
            <i class="bi bi-person-plus-fill me-2"></i> Thêm nhân viên mới
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Search -->
    <form method="get" class="mb-4">
        <div class="input-group shadow-sm rounded">
            <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-search text-muted"></i>
            </span>
            <input type="text" name="SearchTerm" class="form-control border-start-0 ps-0" placeholder="Tìm kiếm nhân viên theo họ tên, email hoặc số điện thoại..." value="@Model.SearchTerm" />
            <button type="submit" class="btn btn-primary px-4">Tìm kiếm</button>
            @if (!string.IsNullOrEmpty(Model.SearchTerm))
            {
                <a href="/Admin/Staff/Index" class="btn btn-outline-secondary">Xóa lọc</a>
            }
        </div>
    </form>

    @if (!Model.Staffs.Any())
    {
        <div class="card border-0 shadow-sm text-center py-5">
            <div class="card-body">
                <div class="mb-3">
                    <i class="bi bi-people text-muted" style="font-size: 3rem;"></i>
                </div>
                <h5 class="text-secondary fw-semibold">Không tìm thấy nhân viên nào</h5>
                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <p class="text-muted">Không tìm thấy kết quả nào phù hợp với từ khóa "<strong>@Model.SearchTerm</strong>".</p>
                    <a href="/Admin/Staff/Index" class="btn btn-outline-primary rounded-pill px-4 mt-2">Xem tất cả nhân viên</a>
                }
                else
                {
                    <p class="text-muted">Chưa có tài khoản nhân viên nào trong hệ thống.</p>
                    <a href="/Admin/Staff/ConfigStaff" class="btn btn-primary rounded-pill px-4 mt-2">Tạo nhân viên đầu tiên</a>
                }
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light border-bottom text-secondary">
                        <tr>
                            <th class="ps-4 py-3">Họ và tên</th>
                            <th class="py-3">Email / Username</th>
                            <th class="py-3">Số điện thoại</th>
                            <th class="py-3 text-center">Vai trò</th>
                            <th class="pe-4 py-3 text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var staff in Model.Staffs)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle me-3 bg-primary bg-opacity-10 text-primary fw-bold">
                                            @(!string.IsNullOrEmpty(staff.FullName) ? staff.FullName.Substring(0, 1).ToUpper() : "N")
                                        </div>
                                        <div>
                                            <span class="fw-semibold text-dark d-block">@staff.FullName</span>
                                            <small class="text-muted">ID: @staff.Id.Substring(0, 8)...</small>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-3">
                                    <span class="text-dark">@staff.Email</span>
                                    @if (staff.User != null && staff.User.EmailConfirmed)
                                    {
                                        <i class="bi bi-patch-check-fill text-success ms-1" title="Đã xác thực email"></i>
                                    }
                                </td>
                                <td class="py-3">
                                    <span class="text-muted">@(string.IsNullOrEmpty(staff.Phone) ? "Chưa cập nhật" : staff.Phone)</span>
                                </td>
                                <td class="py-3 text-center">
                                    <span class="badge bg-info-soft text-info rounded-pill px-3 py-2 fw-medium">Staff</span>
                                </td>
                                <td class="pe-4 py-3 text-end">
                                    <div class="btn-group">
                                        <a href="/Admin/Staff/ConfigStaff/@staff.Id" class="btn btn-sm btn-outline-primary me-2 rounded" title="Chỉnh sửa">
                                            <i class="bi bi-pencil-square"></i> Sửa
                                        </a>
                                        <button type="button" class="btn btn-sm btn-outline-danger rounded" title="Xóa"
                                                data-bs-toggle="modal" data-bs-target="#deleteStaffModal"
                                                data-id="@staff.Id" data-name="@staff.FullName" data-email="@staff.Email">
                                            <i class="bi bi-trash"></i> Xóa
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteStaffModal" tabindex="-1" aria-labelledby="deleteStaffModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-danger" id="deleteStaffModalLabel">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> Xác nhận xóa nhân viên
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4">
                <p class="mb-2 text-dark">Bạn có chắc chắn muốn xóa nhân viên sau đây?</p>
                <div class="bg-light p-3 rounded mb-3 border">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">Họ tên:</span>
                        <strong id="deleteStaffName" class="text-dark"></strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Email:</span>
                        <strong id="deleteStaffEmail" class="text-dark"></strong>
                    </div>
                </div>
                <div class="alert alert-warning mb-0 border-0 shadow-sm py-2">
                    <small><i class="bi bi-info-circle-fill me-1"></i> Tài khoản đăng nhập tương ứng cũng sẽ bị xóa. Các đơn hàng nhân viên này từng phụ trách quản lý sẽ được giải phóng (gán người quản lý thành trống).</small>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy bỏ</button>
                <form method="post" asp-page-handler="Delete">
                    <input type="hidden" name="id" id="deleteStaffId" />
                    <button type="submit" class="btn btn-danger rounded-pill px-4">Đồng ý xóa</button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .avatar-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
    }
    .bg-info-soft {
        background-color: rgba(13, 202, 240, 0.1);
    }
    .btn-group .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
    }
</style>

@section Scripts {
    <script>
        const deleteStaffModal = document.getElementById('deleteStaffModal');
        if (deleteStaffModal) {
            deleteStaffModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                const id = button.getAttribute('data-id');
                const name = button.getAttribute('data-name');
                const email = button.getAttribute('data-email');
                
                document.getElementById('deleteStaffId').value = id;
                document.getElementById('deleteStaffName').textContent = name;
                document.getElementById('deleteStaffEmail').textContent = email;
            });
        }
    </script>
}
