@page "{id:int?}"
@model ProjectSWD.Pages.Admin.Promotion.ConfigPromotionModel
@{
    ViewData["Title"] = Model.IsEdit ? "Chỉnh sửa khuyến mãi" : "Tạo khuyến mãi mới";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Admin/Promotion/Index">Quản lý khuyến mãi</a></li>
            <li class="breadcrumb-item active">@ViewData["Title"]</li>
        </ol>
    </nav>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">@ViewData["Title"]</h4>
        </div>
        <div class="card-body">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="row mb-3">
                    <div class="col-md-8">
                        <label asp-for="Name" class="form-label fw-bold">Tên khuyến mãi <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="VD: Giảm 10% đơn hàng đầu tiên" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-8">
                        <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Mô tả chi tiết về khuyến mãi..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label asp-for="FixedAmount" class="form-label fw-bold">Số tiền giảm (₫)</label>
                        <div class="input-group">
                            <input asp-for="FixedAmount" class="form-control" placeholder="VD: 30000" />
                            <span class="input-group-text">₫</span>
                        </div>
                        <span asp-validation-for="FixedAmount" class="text-danger"></span>
                        <small class="text-muted">Để trống nếu dùng %</small>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Percentage" class="form-label fw-bold">Phần trăm giảm (%)</label>
                        <div class="input-group">
                            <input asp-for="Percentage" class="form-control" placeholder="VD: 10" />
                            <span class="input-group-text">%</span>
                        </div>
                        <span asp-validation-for="Percentage" class="text-danger"></span>
                        <small class="text-muted">Để trống nếu dùng số tiền</small>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label asp-for="StartTime" class="form-label fw-bold">Thời gian bắt đầu <span class="text-danger">*</span></label>
                        <input asp-for="StartTime" class="form-control" type="datetime-local" />
                        <span asp-validation-for="StartTime" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="EndTime" class="form-label fw-bold">Thời gian kết thúc <span class="text-danger">*</span></label>
                        <input asp-for="EndTime" class="form-control" type="datetime-local" />
                        <span asp-validation-for="EndTime" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label asp-for="MinimumOrder" class="form-label fw-bold">Đơn hàng tối thiểu (₫)</label>
                        <div class="input-group">
                            <input asp-for="MinimumOrder" class="form-control" placeholder="VD: 100000" />
                            <span class="input-group-text">₫</span>
                        </div>
                        <span asp-validation-for="MinimumOrder" class="text-danger"></span>
                        <small class="text-muted">Để trống nếu không yêu cầu</small>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="UsageLimit" class="form-label fw-bold">Giới hạn số lượt sử dụng</label>
                        <input asp-for="UsageLimit" class="form-control" placeholder="VD: 100" />
                        <span asp-validation-for="UsageLimit" class="text-danger"></span>
                        <small class="text-muted">Để trống nếu không giới hạn</small>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-8">
                        <label class="form-label fw-bold">Sản phẩm áp dụng</label>
                        <select asp-for="SelectedProductIds" asp-items="Model.ProductOptions" class="form-select" multiple size="8">
                        </select>
                        <small class="text-muted">Giữ Ctrl để chọn nhiều sản phẩm. Để trống nếu áp dụng cho tất cả.</small>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-save"></i> @(Model.IsEdit ? "Cập nhật" : "Tạo mới")
                    </button>
                    <a href="/Admin/Promotion/Index" class="btn btn-secondary px-4">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
