@page
@model ProjectSWD.Pages.Admin.Revenue.IndexModel
@{
    ViewData["Title"] = "Analytics & Financial Reporting";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-4">
    <h2 class="fw-bold mb-4">
        <i class="bi bi-graph-up"></i> @ViewData["Title"]
    </h2>

    <!-- Filter -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label fw-bold">Từ ngày</label>
                    <input type="date" name="StartDate" class="form-control" value="@Model.StartDate.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold">Đến ngày</label>
                    <input type="date" name="EndDate" class="form-control" value="@Model.EndDate.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold">Năm</label>
                    <select name="SelectedYear" class="form-select">
                        @foreach (var y in Model.AvailableYears)
                        {
                            <option value="@y" selected="@(y == Model.SelectedYear.ToString())">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <div class="form-check mt-3">
                        <input type="checkbox" name="CompareWithPreviousYear" class="form-check-input" id="CompareWithPreviousYear"
                               value="true" checked="@(Model.CompareWithPreviousYear)" />
                        <label class="form-check-label" for="CompareWithPreviousYear">
                            📊 So sánh với năm trước (YoY)
                        </label>
                    </div>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-fill">
                        <i class="bi bi-search"></i> Xem báo cáo
                    </button>
                    <a href="/Admin/Revenue/Index?handler=ExportCsv&startDate=@Model.StartDate.ToString("yyyy-MM-dd")&endDate=@Model.EndDate.ToString("yyyy-MM-dd")"
                       class="btn btn-outline-success" title="Export CSV">
                        <i class="bi bi-download"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Summary Cards — BR-16: Net Revenue (deducted refunds) -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 bg-primary text-white">
                <div class="card-body text-center">
                    <h6><i class="bi bi-currency-dollar"></i> Doanh thu gộp</h6>
                    <h3 class="mb-0 fw-bold">@Model.Summary.GrossRevenue.ToString("N0")₫</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 bg-danger text-white">
                <div class="card-body text-center">
                    <h6><i class="bi bi-arrow-return-left"></i> Đã hoàn tiền</h6>
                    <h3 class="mb-0 fw-bold">-@Model.Summary.TotalRefunded.ToString("N0")₫</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 bg-success text-white">
                <div class="card-body text-center">
                    <h6><i class="bi bi-cash-stack"></i> Doanh thu ròng</h6>
                    <h3 class="mb-0 fw-bold">@Model.Summary.NetRevenue.ToString("N0")₫</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 bg-info text-white">
                <div class="card-body text-center">
                    <h6><i class="bi bi-bag-check"></i> Tổng đơn hàng</h6>
                    <h3 class="mb-0 fw-bold">@Model.Summary.TotalOrders</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Daily Revenue Chart -->
        <div class="col-md-8 mb-4">
            <div class="card shadow-sm">
                <div class="card-header bg-white fw-bold d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-bar-chart"></i> Doanh thu theo ngày</span>
                    <a href="/Admin/Revenue/Index?handler=ExportCsv&startDate=@Model.StartDate.ToString("yyyy-MM-dd")&endDate=@Model.EndDate.ToString("yyyy-MM-dd")"
                       class="btn btn-sm btn-outline-success">
                        <i class="bi bi-download"></i> CSV
                    </a>
                </div>
                <div class="card-body">
                    @if (Model.DailyRevenues.Any())
                    {
                        <canvas id="revenueChart" height="250"></canvas>
                    }
                    else
                    {
                        <p class="text-muted text-center my-4">Chưa có dữ liệu doanh thu trong khoảng thời gian này.</p>
                    }
                </div>
            </div>
        </div>

        <!-- Monthly Revenue -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm">
                <div class="card-header bg-white fw-bold">
                    <i class="bi bi-calendar3"></i> Doanh thu theo tháng (@Model.SelectedYear)
                </div>
                <div class="card-body p-0">
                    @if (Model.MonthlyRevenues.Any())
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Tháng</th>
                                    <th class="text-end">Doanh thu</th>
                                    <th class="text-end">Đơn hàng</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.MonthlyRevenues)
                                {
                                    <tr>
                                        <td>Tháng @item.Month</td>
                                        <td class="text-end">@item.Revenue.ToString("N0")₫</td>
                                        <td class="text-end">@item.OrderCount</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted text-center my-4">Chưa có dữ liệu.</p>
                    }
                </div>
            </div>

            @* A1: Year-over-Year comparison *@
            @if (Model.Comparison != null && Model.Comparison.CurrentMonths.Any())
            {
                <div class="card shadow-sm mt-3">
                    <div class="card-header bg-white fw-bold">
                        <i class="bi bi-arrow-left-right"></i> So sánh YoY: @Model.Comparison.PreviousYear vs @Model.Comparison.CurrentYear
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Tháng</th>
                                    <th class="text-end">@Model.Comparison.PreviousYear</th>
                                    <th class="text-end">@Model.Comparison.CurrentYear</th>
                                    <th class="text-end">Tăng trưởng</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int m = 1; m <= 12; m++)
                                {
                                    var prev = Model.Comparison.PreviousMonths.FirstOrDefault(p => p.Month == m);
                                    var curr = Model.Comparison.CurrentMonths.FirstOrDefault(p => p.Month == m);
                                    if (prev == null && curr == null) { continue; }

                                    var prevRev = prev?.Revenue ?? 0;
                                    var currRev = curr?.Revenue ?? 0;
                                    var growth = prevRev > 0 ? ((currRev - prevRev) / prevRev * 100).ToString("+0.0;-0.0;0") : "N/A";

                                    <tr>
                                        <td>Tháng @m</td>
                                        <td class="text-end">@prevRev.ToString("N0")₫</td>
                                        <td class="text-end">@currRev.ToString("N0")₫</td>
                                        <td class="text-end fw-bold @(currRev >= prevRev ? "text-success" : "text-danger")">
                                            @growth@(growth != "N/A" ? "%" : "")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="row">
        <!-- Top Selling Products -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm">
                <div class="card-header bg-white fw-bold">
                    <i class="bi bi-trophy"></i> Top 10 sản phẩm bán chạy
                </div>
                <div class="card-body p-0">
                    @if (Model.TopProducts.Any())
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Sản phẩm</th>
                                    <th class="text-end">SL bán</th>
                                    <th class="text-end">Doanh thu</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.TopProducts.Count; i++)
                                {
                                    var p = Model.TopProducts[i];
                                    <tr>
                                        <td>@(i + 1)</td>
                                        <td>@p.ProductName</td>
                                        <td class="text-end">@p.TotalQuantity.ToString("N2")</td>
                                        <td class="text-end fw-bold text-success">@p.TotalRevenue.ToString("N0")₫</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted text-center my-4">Chưa có dữ liệu.</p>
                    }
                </div>
            </div>
        </div>

        <!-- Revenue by Category -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm">
                <div class="card-header bg-white fw-bold">
                    <i class="bi bi-tags"></i> Doanh thu theo danh mục
                </div>
                <div class="card-body p-0">
                    @if (Model.CategoryRevenues.Any())
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Danh mục</th>
                                    <th class="text-end">Doanh thu</th>
                                    <th class="text-end">Đơn hàng</th>
                                    <th class="text-end">Tỉ trọng</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in Model.CategoryRevenues)
                                {
                                    var total = Model.CategoryRevenues.Sum(x => x.Revenue);
                                    var pct = total > 0 ? (c.Revenue / total * 100).ToString("0.0") : "0";
                                    <tr>
                                        <td>@c.CategoryName</td>
                                        <td class="text-end">@c.Revenue.ToString("N0")₫</td>
                                        <td class="text-end">@c.OrderCount</td>
                                        <td class="text-end">@pct%</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted text-center my-4">Chưa có dữ liệu.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        @if (Model.DailyRevenues.Any())
        {
            <text>
            const ctx = document.getElementById('revenueChart').getContext('2d');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: [@string.Join(", ", Model.DailyRevenues.Select(d => $"'{d.Date.ToString("dd/MM")}'"))],
                    datasets: [
                        {
                            label: 'Doanh thu (₫)',
                            data: [@string.Join(", ", Model.DailyRevenues.Select(d => d.Revenue))],
                            backgroundColor: 'rgba(13, 110, 253, 0.6)',
                            borderColor: 'rgba(13, 110, 253, 1)',
                            borderWidth: 1,
                            yAxisID: 'y'
                        },
                        {
                            label: 'Đơn hàng',
                            data: [@string.Join(", ", Model.DailyRevenues.Select(d => d.OrderCount))],
                            backgroundColor: 'rgba(25, 135, 84, 0.6)',
                            borderColor: 'rgba(25, 135, 84, 1)',
                            borderWidth: 1,
                            yAxisID: 'y1'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    interaction: { mode: 'index', intersect: false },
                    scales: {
                        y: {
                            type: 'linear',
                            display: true,
                            position: 'left',
                            title: { display: true, text: 'Doanh thu (₫)' },
                            ticks: { callback: v => v.toLocaleString() + '₫' }
                        },
                        y1: {
                            type: 'linear',
                            display: true,
                            position: 'right',
                            title: { display: true, text: 'Đơn hàng' },
                            grid: { drawOnChartArea: false },
                            ticks: { stepSize: 1 }
                        }
                    }
                }
            });
            </text>
        }
    </script>
}
