@page
@using ProjectSWD.Data.Enums
@model ProjectSWD.Pages.Admin.Refunds.IndexModel
@{
    ViewData["Title"] = "Refund Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Refund Requests</h2>
        <form method="get" class="d-flex align-items-center">
            <label for="statusFilter" class="me-2 text-nowrap">Filter by Status:</label>
            <select id="statusFilter" name="StatusFilter" class="form-select form-select-sm me-2" onchange="this.form.submit()">
                <option value="">All</option>
                <option value="PendingReview" selected="@(Model.StatusFilter == RefundStatus.PendingReview ? "selected" : null)">Pending Review</option>
                <option value="Refunded" selected="@(Model.StatusFilter == RefundStatus.Refunded ? "selected" : null)">Refunded</option>
                <option value="Rejected" selected="@(Model.StatusFilter == RefundStatus.Rejected ? "selected" : null)">Rejected</option>
            </select>
        </form>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Request ID</th>
                    <th>Customer</th>
                    <th>Amount</th>
                    <th>Requested Date</th>
                    <th>Status</th>
                    <th>Reason</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Refunds != null && Model.Refunds.Any())
                {
                    @foreach (var item in Model.Refunds)
                    {
                        <tr>
                            <td>#@item.Id</td>
                            <td>@(item.Order?.Customer?.FullName ?? "N/A")</td>
                            <td class="text-danger fw-bold">@item.Amount.ToString("N0") VND</td>
                            <td>@item.CreatedAt.ToString("MM/dd/yyyy HH:mm")</td>
                            <td>
                                @if (item.Status == RefundStatus.PendingReview)
                                {
                                    <span class="badge bg-warning text-dark">Pending Review</span>
                                }
                                else if (item.Status == RefundStatus.Refunded)
                                {
                                    <span class="badge bg-success">Refunded</span>
                                }
                                else if (item.Status == RefundStatus.Rejected)
                                {
                                    <span class="badge bg-danger">Rejected</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Reason) && item.Reason.Length > 50)
                                {
                                    <span title="@item.Reason">@item.Reason.Substring(0, 50)...</span>
                                }
                                else
                                {
                                    @item.Reason
                                }
                            </td>
                            <td>
                                <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary">View Details</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-3">No refund requests found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
