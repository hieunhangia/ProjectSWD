@model ProjectSWD.Data.Entities.Order
@{
    ViewData["Title"] = "Đặt Hàng Thành Công";
    var subtotal = Model.OrderItems.Sum(oi => oi.Price * oi.Quantity);
    var shippingFee = Model.TotalPrice - subtotal;
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-9 col-lg-8">
            <div class="card invoice-card shadow-lg">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <div class="success-badge-pulse mb-3">
                            <i class="bi bi-check-lg"></i>
                        </div>
                        <h3 class="text-success fw-bold-700 mb-2">ĐẶT HÀNG THÀNH CÔNG!</h3>
                        <p class="text-muted small">Cảm ơn bạn đã mua sắm tại Gia Hoa Phat System. Đơn hàng của bạn đã được tiếp nhận và đang xử lý.</p>
                    </div>

                    <div class="bg-light rounded-3 p-4 mb-4 border shadow-2xs">
                        <div class="row g-3">
                            <div class="col-sm-6">
                                <span class="text-muted d-block small fw-semibold text-uppercase tracking-wider">MÃ ĐƠN HÀNG</span>
                                <strong class="fs-5 text-primary">#ORD-@Model.Id</strong>
                            </div>
                            <div class="col-sm-6 text-sm-end">
                                <span class="text-muted d-block small fw-semibold text-uppercase tracking-wider">THỜI GIAN ĐẶT</span>
                                <strong class="text-dark">@Model.Time.ToString("dd/MM/yyyy HH:mm")</strong>
                            </div>

                            <div class="col-12 my-2"><hr class="my-1"></div>

                            <div class="col-sm-6">
                                <span class="text-muted d-block small fw-semibold text-uppercase tracking-wider">THÔNG TIN GIAO HÀNG</span>
                                <strong class="text-dark">@Model.FullName</strong>
                                <span class="d-block small text-muted mt-1"><i class="bi bi-telephone me-1"></i>SĐT: @Model.PhoneNumber</span>
                                <span class="d-block small text-muted"><i class="bi bi-geo-alt me-1"></i>Địa chỉ: @Model.Address</span>
                            </div>
                            <div class="col-sm-6 text-sm-end">
                                <span class="text-muted d-block small fw-semibold text-uppercase tracking-wider">TRẠNG THÁI ĐƠN HÀNG</span>
                                <strong class="text-dark">@Model.ApprovementStatus.ToString()</strong>
                                <span class="d-block small text-success mt-1"><i class="bi bi-shield-check me-1"></i>Hệ thống đã ghi nhận</span>
                            </div>
                        </div>
                    </div>

                    <h5 class="fw-bold-700 mb-3 text-dark"><i class="bi bi-card-checklist me-2 text-primary"></i>Sản phẩm đã mua</h5>
                    <div class="table-responsive mb-4 border rounded">
                        <table class="table align-middle mb-0">
                            <thead class="table-light text-uppercase small">
                                <tr>
                                    <th class="ps-3" style="font-size: 0.75rem;">Tên Sản Phẩm</th>
                                    <th class="text-end" style="font-size: 0.75rem;">Đơn Giá</th>
                                    <th class="text-center" style="font-size: 0.75rem;">SL</th>
                                    <th class="text-end pe-3" style="font-size: 0.75rem;">Tổng</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.OrderItems)
                                {
                                    <tr>
                                        <td class="ps-3">
                                            <div class="fw-semibold-600 text-dark">@item.Product.Name</div>
                                            <span class="text-muted small" style="font-size: 0.75rem;">Mã SP: #@item.ProductId</span>
                                        </td>
                                        <td class="text-end">@item.Price.ToString("N0") đ</td>
                                        <td class="text-center font-monospace">@item.Quantity.ToString("G29")</td>
                                        <td class="text-end pe-3 fw-bold text-dark">@((item.Price * item.Quantity).ToString("N0")) đ</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="row justify-content-end mb-4">
                        <div class="col-md-6 col-lg-5">
                            <div class="d-flex justify-content-between mb-2 small">
                                <span class="text-muted">Tiền hàng:</span>
                                <span class="fw-semibold text-dark">@subtotal.ToString("N0") đ</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2 small">
                                <span class="text-muted">Phí vận chuyển:</span>
                                <span class="fw-semibold text-dark">@shippingFee.ToString("N0") đ</span>
                            </div>
                            <hr class="my-2">
                            <div class="d-flex justify-content-between align-items-baseline">
                                <span class="fs-6 fw-bold text-dark">Tổng thanh toán:</span>
                                <span class="fs-5 fw-bold text-primary">@Model.TotalPrice.ToString("N0") đ</span>
                            </div>
                        </div>
                    </div>

                    <div class="text-center">
                        <a href="/" class="btn btn-gradient btn-lg px-5 py-3">
                            <i class="bi bi-house-door me-2"></i> Quay lại trang chủ
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        --primary-color: #1e3c72;
        --base-font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
        --bg-light-gray: #F2F2F7;
        --text-dark: #1C1C1E;
        --text-muted: #8E8E93;
        --card-border-radius: 20px;
    }

    body {
        font-family: var(--base-font-family);
        background-color: var(--bg-light-gray);
        color: var(--text-dark);
    }

    .fw-bold-700 {
        font-weight: 700;
    }

    .fw-semibold-600 {
        font-weight: 600;
    }

    .invoice-card {
        border: none;
        border-radius: var(--card-border-radius);
        background-color: #fff;
    }

    .btn-gradient {
        background: var(--primary-gradient);
        border: none;
        color: #ffffff;
        font-weight: 700;
        letter-spacing: 0.5px;
        padding: 0.85rem 2rem;
        border-radius: 10px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(30, 60, 114, 0.2);
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .btn-gradient:hover {
        background: linear-gradient(135deg, #152b52 0%, #1e3c72 100%);
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(30, 60, 114, 0.3);
        color: #fff;
    }

    .success-badge-pulse {
        width: 80px;
        height: 80px;
        background-color: #d1fae5;
        color: #10b981;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4);
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            transform: scale(0.95);
            box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
        }
        70% {
            transform: scale(1);
            box-shadow: 0 0 0 15px rgba(16, 185, 129, 0);
        }
        100% {
            transform: scale(0.95);
            box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
        }
    }

    .shadow-2xs {
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    }
</style>
