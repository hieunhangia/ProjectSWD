@using ProjectSWD.Data.Enums
@model ProjectSWD.Data.Entities.Order

@{
    ViewData["Title"] = "Chi Tiết Đơn Hàng #" + Model.Id;
    var subtotal = Model.OrderItems.Sum(oi => oi.Price * oi.Quantity);
    var shippingFee = Model.TotalPrice - subtotal;

    var currentStatus = Model.Status;
    string progressWidth = "0%";
    if (currentStatus == OrderStatus.Confirmed) progressWidth = "33.33%";
    else if (currentStatus == OrderStatus.InTransit) progressWidth = "66.66%";
    else if (currentStatus == OrderStatus.Delivered) progressWidth = "100%";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>



<div class="container mt-4 mb-5" style="max-width: 1000px;">
    @Html.AntiForgeryToken()
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="d-flex align-items-start justify-content-between mb-4">
                <a href="/OrderHistory" class="btn btn-outline-secondary px-3 py-2" style="border-radius: 8px; font-weight: 600;">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại lịch sử
                </a>
                <div class="text-end">
                    <div class="d-flex gap-2 justify-content-end mb-1">
                        <button type="button"
                                id="btn-cancel-order"
                                class="btn btn-danger px-4 py-2"
                                style="border-radius: 8px; font-weight: 600;"
                                @(currentStatus == OrderStatus.AwaitingConfirmation ? "" : "disabled")
                                onclick="confirmCancelOrder()">
                            <i class="bi bi-x-circle me-1"></i> Hủy Đơn Hàng
                        </button>

                        <button type="button"
                                id="btn-track-status"
                                class="btn btn-success px-4 py-2 @(currentStatus is OrderStatus.Delivered or OrderStatus.Cancelled ? "d-none" : "")"
                                style="border-radius: 8px; font-weight: 600;"
                                @(currentStatus != OrderStatus.AwaitingConfirmation ? "" : "disabled")
                                onclick="advanceTracking()">
                            <span class="spinner-border spinner-border-sm d-none me-2" id="track-spinner" role="status" aria-hidden="true"></span>
                            <i class="bi bi-geo-alt me-1" id="track-icon"></i> Kiểm tra trạng thái
                        </button>
                    </div>
                    <small class="text-muted d-block" style="font-size: 0.75rem;"><i class="bi bi-info-circle me-1"></i>Chỉ có thể hủy đơn hàng khi trạng thái đang là CHỜ XÁC NHẬN</small>
                </div>
            </div>

            <div id="cancellation-alert" class="alert alert-danger d-flex align-items-center mb-4 @(currentStatus == OrderStatus.Cancelled ? "" : "d-none")" role="alert" style="border-radius: 12px;">
                <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
                <div>
                    <h6 class="alert-heading fw-bold mb-1">Đơn hàng này đã bị hủy!</h6>
                    <span>Bạn không thể kiểm tra hoặc khôi phục trạng thái cho đơn hàng đã hủy.</span>
                </div>
            </div>

            <div class="card details-card">
                <div class="card-header-custom d-flex flex-wrap align-items-center justify-content-between gap-3">
                    <div>
                        <span class="text-muted d-block small fw-bold text-uppercase tracking-wider">Chi Tiết Đơn Hàng</span>
                        <h4 class="fw-bold text-dark mb-0">Mã Đơn: #ORD-@Model.Id</h4>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <span class="text-muted text-sm">Thời gian: <strong>@Model.Time.ToString("dd/MM/yyyy HH:mm")</strong></span>
                        <div id="status-badge-container">
                            @if (currentStatus == OrderStatus.Cancelled)
                            {
                                <span class="badge bg-danger-subtle text-danger status-badge">Đã Hủy</span>
                            }
                            else if (currentStatus == OrderStatus.AwaitingConfirmation)
                            {
                                <span class="badge bg-warning-subtle text-warning status-badge">Chờ Xác Nhận</span>
                            }
                            else if (currentStatus == OrderStatus.Confirmed)
                            {
                                <span class="badge bg-primary-subtle text-primary status-badge">Đã Xác Nhận</span>
                            }
                            else if (currentStatus == OrderStatus.InTransit)
                            {
                                <span class="badge bg-info-subtle text-info status-badge">Đang Giao Hàng</span>
                            }
                            else if (currentStatus == OrderStatus.Delivered)
                            {
                                <span class="badge bg-success-subtle text-success status-badge">Đã Giao Thành Công</span>
                            }
                        </div>
                    </div>
                </div>
                
                @{
                    var statusValue = currentStatus switch
                    {
                        OrderStatus.Cancelled => 0,
                        OrderStatus.AwaitingConfirmation => 1,
                        OrderStatus.Confirmed => 2,
                        OrderStatus.InTransit => 3,
                        OrderStatus.Delivered => 4,
                        _ => 1
                    };
                }

                <div class="card-body p-4">

                    <div class="timeline-stepper">
                        <div class="stepper-progress" style="width: @progressWidth;"></div>

                        <div class="stepper-step @(statusValue >= 1 ? "active" : "")" id="step-1">
                            <div class="step-circle">
                                <i class="bi bi-hourglass-split"></i>
                            </div>
                            <div class="step-title">Chờ Xác Nhận</div>
                        </div>

                        <div class="stepper-step @(statusValue >= 2 ? "active" : "")" id="step-2">
                            <div class="step-circle">
                                <i class="bi bi-check-circle"></i>
                            </div>
                            <div class="step-title">Đã Xác Nhận</div>
                        </div>

                        <div class="stepper-step @(statusValue >= 3 ? "active" : "")" id="step-3">
                            <div class="step-circle">
                                <i class="bi bi-truck"></i>
                            </div>
                            <div class="step-title">Đang Giao Hàng</div>
                        </div>

                        <div class="stepper-step @(statusValue >= 4 ? "active" : "")" id="step-4">
                            <div class="step-circle">
                                <i class="bi bi-house-check"></i>
                            </div>
                            <div class="step-title">Đã Giao</div>
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="row g-4">
                        <div class="col-md-5">
                            <h5 class="fw-bold mb-3 text-dark">Thông Tin Giao Nhận</h5>
                            <div class="info-card">
                                <div class="mb-3">
                                    <span class="text-muted d-block small">Họ và Tên</span>
                                    <strong class="text-dark">@Model.FullName</strong>
                                </div>
                                <div class="mb-3">
                                    <span class="text-muted d-block small">Số Điện Thoại</span>
                                    <strong class="text-dark"><i class="bi bi-telephone me-1"></i>@Model.PhoneNumber</strong>
                                </div>
                                <div class="mb-0">
                                    <span class="text-muted d-block small">Địa Chỉ Nhận Hàng</span>
                                    <strong class="text-dark"><i class="bi bi-geo-alt me-1"></i>@Model.Address</strong>
                                </div>
                            </div>
                        </div>


                        <div class="col-md-7">
                            <h5 class="fw-bold mb-3 text-dark">Danh Sách Sản Phẩm</h5>
                            <div class="table-responsive border rounded-3 bg-white">
                                <table class="table table-sm align-middle mb-0" style="font-size: 0.85rem;">
                                    <thead class="table-light text-uppercase small" style="font-size: 0.7rem;">
                                        <tr>
                                            <th class="ps-3">Sản Phẩm</th>
                                            <th class="text-end">Đơn Giá</th>
                                            <th class="text-center">Số Lượng</th>
                                            <th class="text-end pe-3">Tổng</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.OrderItems)
                                        {
                                            <tr>
                                                <td class="ps-3">
                                                    <div class="d-flex align-items-center">
                                                        <div>
                                                            <div class="fw-semibold text-dark">@(item.Product?.Name ?? "Sản phẩm")</div>
                                                            <div class="mt-1">
                                                                <span class="text-muted small" style="font-size: 0.75rem; display: block; margin-bottom: 4px;">Mã: #@item.ProductId</span>
                                                                @if (Model.Status == OrderStatus.Delivered)
                                                                {
                                                                    <div class="d-flex flex-wrap gap-2 mt-1">
                                                                        <a href="/Customer/MyOrders/RateProduct/@Model.Id/@item.ProductId" class="badge bg-primary-subtle text-primary border-0 text-decoration-none" style="font-size: 0.7rem; font-weight: 600; padding: 4px 8px;">
                                                                            <i class="bi bi-star-fill me-1"></i>Đánh giá
                                                                        </a>
                                                                        <a href="/Customer/MyOrders/RequestRefund/@Model.Id/@item.ProductId" class="badge bg-danger-subtle text-danger border-0 text-decoration-none" style="font-size: 0.7rem; font-weight: 600; padding: 4px 8px;">
                                                                            <i class="bi bi-arrow-counterclockwise me-1"></i>Hoàn tiền
                                                                        </a>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="text-end text-nowrap">@item.Price.ToString("N0") đ</td>
                                                <td class="text-center font-monospace">@item.Quantity.ToString("G29")</td>
                                                <td class="text-end pe-3 fw-bold text-dark text-nowrap">@((item.Price * item.Quantity).ToString("N0")) đ</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <div class="card border-0 mt-3 p-3 bg-light rounded-3">
                                <div class="d-flex justify-content-between mb-2 small text-muted">
                                    <span>Tạm tính hàng hóa:</span>
                                    <span class="fw-semibold text-dark">@subtotal.ToString("N0") đ</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2 small text-muted">
                                    <span>Phí giao hàng:</span>
                                    <span class="fw-semibold text-dark">@shippingFee.ToString("N0") đ</span>
                                </div>
                                <hr class="my-2">
                                <div class="d-flex justify-content-between align-items-baseline">
                                    <strong class="text-dark">Tổng cộng:</strong>
                                    <strong class="text-primary fs-4">@Model.TotalPrice.ToString("N0") đ</strong>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

<!-- Cancel Confirmation Modal -->
<div class="modal fade" id="cancelConfirmationModal" tabindex="-1" aria-labelledby="cancelModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 16px; border: none; box-shadow: 0 20px 40px rgba(0,0,0,0.15);">
            <div class="modal-body p-4 text-center">
                <div class="text-danger mb-3">
                    <i class="bi bi-x-circle-fill" style="font-size: 3rem;"></i>
                </div>
                <h5 class="fw-bold mb-2 text-dark">Xác Nhận Hủy Đơn Hàng?</h5>
                <p class="text-muted small">Bạn có chắc chắn muốn hủy đơn hàng này không? Hành động này sẽ không thể khôi phục lại trạng thái cũ.</p>
                <div class="d-flex gap-2 justify-content-center mt-4">
                    <button type="button" class="btn btn-light px-4 py-2" data-bs-dismiss="modal" style="border-radius: 8px; font-weight: 600;">Quay Lại</button>
                    <button type="button" class="btn btn-danger px-4 py-2" onclick="executeCancelOrder()" style="border-radius: 8px; font-weight: 600;">Đồng Ý Hủy</button>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    const orderId = @Model.Id;

    // Show Cancellation Modal
    function confirmCancelOrder() {
        const modal = new bootstrap.Modal(document.getElementById('cancelConfirmationModal'));
        modal.show();
    }

    // Call AJAX to Cancel Order
    function executeCancelOrder() {
        const modalEl = document.getElementById('cancelConfirmationModal');
        const modalInstance = bootstrap.Modal.getInstance(modalEl);
        if (modalInstance) {
            modalInstance.hide();
        }

        // Get antiforgery token
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

        const formData = new FormData();
        formData.append("orderId", orderId);
        if (token) {
            formData.append("__RequestVerificationToken", token);
        }

        fetch('/OrderHistory/CancelOrder', {
            method: 'POST',
            headers: {
                'RequestVerificationToken': token || ''
            },
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Update UI state to Cancelled
                updateUI("Cancelled", 0);
            } else {
                alert(data.message || "Không thể hủy đơn hàng.");
            }
        })
        .catch(error => {
            console.error("Error cancelling order:", error);
            alert("Có lỗi xảy ra khi thực hiện hủy đơn hàng.");
        });
    }

    // Call AJAX to Advance Status
    function advanceTracking() {
        const spinner = document.getElementById("track-spinner");
        const icon = document.getElementById("track-icon");
        const btn = document.getElementById("btn-track-status");

        // Show spinner & disable button
        spinner.classList.remove("d-none");
        icon.classList.add("d-none");
        btn.disabled = true;

        // Get antiforgery token
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

        const formData = new FormData();
        formData.append("orderId", orderId);
        if (token) {
            formData.append("__RequestVerificationToken", token);
        }

        fetch('/OrderHistory/AdvanceTracking', {
            method: 'POST',
            headers: {
                'RequestVerificationToken': token || ''
            },
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            // Restore button state
            spinner.classList.add("d-none");
            icon.classList.remove("d-none");
            btn.disabled = false;

             if (data.success) {
                 // Update UI timeline and buttons based on new status
                 updateUI(data.newStatus, data.statusCode);
                 if (data.newStatus === "Delivered Successfully") {
                     setTimeout(() => {
                         location.reload();
                     }, 500);
                 }
             } else {
                alert(data.message || "Không thể cập nhật trạng thái.");
            }
        })
        .catch(error => {
            spinner.classList.add("d-none");
            icon.classList.remove("d-none");
            btn.disabled = false;
            console.error("Error advancing tracking:", error);
            alert("Có lỗi xảy ra khi cập nhật trạng thái.");
        });
    }

    // Dynamic UI Update logic
    function updateUI(statusName, statusCode) {
        // Update status badge
        const badgeEl = document.getElementById("status-badge-container");
        if (badgeEl) {
            let badgeHtml = '';
            if (statusName === "Cancelled") {
                badgeHtml = '<span class="badge bg-danger-subtle text-danger status-badge">Đã Hủy</span>';
            } else if (statusName === "Awaiting Confirmation") {
                badgeHtml = '<span class="badge bg-warning-subtle text-warning status-badge">Chờ Xác Nhận</span>';
            } else if (statusName === "Confirmed") {
                badgeHtml = '<span class="badge bg-primary-subtle text-primary status-badge">Đã Xác Nhận</span>';
            } else if (statusName === "In Transit") {
                badgeHtml = '<span class="badge bg-info-subtle text-info status-badge">Đang Giao Hàng</span>';
            } else if (statusName === "Delivered Successfully") {
                badgeHtml = '<span class="badge bg-success-subtle text-success status-badge">Đã Giao Thành Công</span>';
            } else {
                badgeHtml = `<span class="badge bg-secondary-subtle text-secondary status-badge">${statusName}</span>`;
            }
            badgeEl.innerHTML = badgeHtml;
        }

        // Update timeline stepper
        if (statusName === "Cancelled") {
            document.querySelectorAll(".stepper-step").forEach(step => step.classList.remove("active"));
            const progressBar = document.querySelector(".stepper-progress");
            if (progressBar) progressBar.style.width = "0%";

            // Show cancellation notice
            const cancelAlert = document.getElementById("cancellation-alert");
            if (cancelAlert) cancelAlert.classList.remove("d-none");
        } else {
            const cancelAlert = document.getElementById("cancellation-alert");
            if (cancelAlert) cancelAlert.classList.add("d-none");

            for (let i = 1; i <= 4; i++) {
                const stepEl = document.getElementById(`step-${i}`);
                if (stepEl) {
                    if (i <= statusCode) {
                        stepEl.classList.add("active");
                    } else {
                        stepEl.classList.remove("active");
                    }
                }
            }

            const progressBar = document.querySelector(".stepper-progress");
            if (progressBar) {
                let width = "0%";
                if (statusCode === 2) width = "33.33%";
                else if (statusCode === 3) width = "66.66%";
                else if (statusCode >= 4) width = "100%";
                progressBar.style.width = width;
            }
        }

        const cancelBtn = document.getElementById("btn-cancel-order");
        if (cancelBtn) {
            if (statusName === "Awaiting Confirmation") {
                cancelBtn.disabled = false;
            } else {
                cancelBtn.disabled = true;
            }
        }

        const trackBtn = document.getElementById("btn-track-status");
        if (trackBtn) {
            if (statusName === "Delivered Successfully" || statusName === "Cancelled" || statusCode >= 4) {
                trackBtn.classList.add("d-none");
            } else {
                trackBtn.classList.remove("d-none");
            }
        }
    }
</script>
<style>
    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background-color: #f8f9fa;
    }

    .details-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.04);
        background: #ffffff;
    }

    .card-header-custom {
        background-color: #ffffff;
        border-bottom: 1px solid #f1f3f5;
        border-top-left-radius: 16px !important;
        border-top-right-radius: 16px !important;
        padding: 24px;
    }

    .info-card {
        background-color: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 12px;
        padding: 20px;
    }

    .product-img {
        width: 60px;
        height: 60px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid #e9ecef;
    }

    /* Horizontal Timeline Stepper */
    .timeline-stepper {
        position: relative;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin: 40px 0 20px 0;
        padding: 0 10px;
    }

        .timeline-stepper::before {
            content: '';
            position: absolute;
            top: 25px;
            left: 0;
            right: 0;
            height: 4px;
            background-color: #e9ecef;
            z-index: 1;
        }

    .stepper-progress {
        position: absolute;
        top: 25px;
        left: 0;
        height: 4px;
        background-color: #198754;
        z-index: 1;
        transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .stepper-step {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 140px;
    }

    .step-circle {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background-color: #ffffff;
        border: 3px solid #e9ecef;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 1.2rem;
        color: #a0aec0;
        transition: all 0.4s ease;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
    }

    .stepper-step.active .step-circle {
        background-color: #198754;
        border-color: #198754;
        color: #ffffff;
        box-shadow: 0 10px 15px -3px rgba(25, 135, 84, 0.3);
    }

    .step-title {
        margin-top: 10px;
        font-size: 0.8rem;
        font-weight: 700;
        color: #718096;
        text-align: center;
        transition: color 0.4s ease;
    }

    .stepper-step.active .step-title {
        color: #198754;
    }

    .status-badge {
        font-size: 0.85rem;
        font-weight: 700;
        padding: 6px 16px;
        border-radius: 20px;
    }
</style>