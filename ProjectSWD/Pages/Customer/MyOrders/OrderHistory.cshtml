@using ProjectSWD.Data.Enums
@model List<ProjectSWD.Data.Entities.Order>
@{
    ViewData["Title"] = "Lịch sử mua hàng";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">



<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h2 class="fw-bold text-dark mb-1"><i class="bi bi-clock-history me-2 text-primary"></i>Lịch Sử Mua Hàng</h2>
                    <p class="text-muted mb-0">Theo dõi trạng thái và chi tiết các đơn hàng của bạn</p>
                </div>
                <a href="/Cart" class="btn btn-outline-secondary btn-detail">
                    <i class="bi bi-cart3 me-1"></i> Quay lại giỏ hàng
                </a>
            </div>

            @if (Model == null || !Model.Any())
            {
                <div class="card order-history-card py-5 px-4 text-center">
                    <div class="mb-3">
                        <i class="bi bi-clipboard-x text-muted" style="font-size: 4rem;"></i>
                    </div>
                    <h5 class="text-muted mt-2 mb-3">Bạn chưa có đơn hàng nào!</h5>
                    <p class="text-muted small mb-4">Hãy bắt đầu chọn những nguyên liệu làm bánh tuyệt vời và thực hiện đặt hàng đầu tiên của bạn.</p>
                    <a href="/Cart" class="btn btn-primary px-4 py-2" style="border-radius: 8px; font-weight: 600;">
                        Mua Sắm Ngay
                    </a>
                </div>
            }
            else
            {
                <div class="card order-history-card">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table order-table mb-0">
                                <thead>
                                    <tr>
                                        <th class="ps-4">Mã Đơn Hàng</th>
                                        <th>Thời Gian Đặt</th>
                                        <th>Người Nhận</th>
                                        <th>Tổng Thanh Toán</th>
                                        <th class="text-center">Trạng Thái</th>
                                        <th class="text-end pe-4">Thao Tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <strong class="text-primary">#ORD-@order.Id</strong>
                                            </td>
                                            <td>
                                                <span class="text-dark">@order.Time.ToString("dd/MM/yyyy HH:mm")</span>
                                            </td>
                                            <td>
                                                <div class="fw-semibold text-dark">@order.FullName</div>
                                                <div class="text-muted small"><i class="bi bi-telephone me-1"></i>@order.PhoneNumber</div>
                                            </td>
                                            <td>
                                                <strong class="text-dark">@order.TotalPrice.ToString("N0") đ</strong>
                                            </td>
                                            <td class="text-center">
                                                @if (order.Status == OrderStatus.Cancelled)
                                                {
                                                    <span class="badge bg-danger-subtle text-danger status-badge">Đã Hủy</span>
                                                }
                                                else if (order.Status == OrderStatus.AwaitingConfirmation)
                                                {
                                                    <span class="badge bg-warning-subtle text-warning status-badge">Chờ Xác Nhận</span>
                                                }
                                                else if (order.Status == OrderStatus.Confirmed)
                                                {
                                                    <span class="badge bg-primary-subtle text-primary status-badge">Đã Xác Nhận</span>
                                                }
                                                else if (order.Status == OrderStatus.InTransit)
                                                {
                                                    <span class="badge bg-info-subtle text-info status-badge">Đang Giao Hàng</span>
                                                }
                                                else if (order.Status == OrderStatus.Delivered)
                                                {
                                                    <span class="badge bg-success-subtle text-success status-badge">Đã Giao Thành Công</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary-subtle text-secondary status-badge">@order.Status</span>
                                                }
                                            </td>
                                            <td class="text-end pe-4">
                                                <a href="/OrderHistory/Details/@order.Id" class="btn btn-outline-primary btn-detail">
                                                    <i class="bi bi-eye me-1"></i> Chi tiết
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background-color: #f8f9fa;
    }

    .order-history-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.04);
        background: #ffffff;
    }

    .order-table th {
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.8px;
        color: #6c757d;
        border-bottom: 2px solid #f1f3f5;
        padding-top: 16px;
        padding-bottom: 16px;
    }

    .order-table td {
        padding-top: 20px;
        padding-bottom: 20px;
        vertical-align: middle;
        border-bottom: 1px solid #f1f3f5;
    }

    .btn-detail {
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.875rem;
        padding: 6px 16px;
        transition: all 0.2s ease;
    }

        .btn-detail:hover {
            background-color: #0d6efd;
            color: #fff;
            transform: translateY(-1px);
        }

    .status-badge {
        font-size: 0.75rem;
        font-weight: 700;
        padding: 6px 12px;
        border-radius: 20px;
    }
</style>