@model List<ProjectSWD.DTOs.CartItemDTO>
@{
    ViewData["Title"] = "Giỏ Hàng Của Bạn";
    var totalAmount = Model.Sum(x => x.TotalPrice);
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-4 mb-5" style="max-width: 1000px;">
    <div class="text-center mb-4">
        <h2 class="fw-bold-700 text-dark mb-1">Gia Hoa Phat System</h2>
        <p class="text-muted">Quản lý các sản phẩm bạn đã chọn trước khi thanh toán</p>
    </div>

    <div class="checkout-stepper">
        <div class="stepper-item active">
            <div class="stepper-circle"><i class="bi bi-cart"></i></div>
            <div class="stepper-text">Giỏ Hàng</div>
        </div>
        <div class="stepper-item">
            <div class="stepper-circle"><i class="bi bi-truck"></i></div>
            <div class="stepper-text">Giao Hàng & Thanh Toán</div>
        </div>
        <div class="stepper-item">
            <div class="stepper-circle"><i class="bi bi-receipt"></i></div>
            <div class="stepper-text">Hoàn Thành</div>
        </div>
    </div>

    <div class="row" id="cartMainSection">
        @if (Model == null || !Model.Any())
        {
            <div class="col-12">
                <div class="card cart-card py-5 px-4 text-center">
                    <i class="bi bi-cart-x text-muted" style="font-size: 4rem;"></i>
                    <h5 class="text-muted mt-3 mb-3">Giỏ hàng của bạn hiện đang trống!</h5>
                    <p class="text-muted small mb-4">Hãy thêm các nguyên liệu làm bánh tươi ngon vào giỏ để tiếp tục trải nghiệm mua sắm.</p>
                    <a href="/Cart/AddDummyToCart" class="btn btn-outline-gradient">
                        <i class="bi bi-plus-circle me-2"></i> Thêm sản phẩm mẫu thử nghiệm
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="col-lg-8 mb-4">
                <div class="card cart-card h-100">
                    <div class="card-header cart-card-header d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center">
                            <span class="card-title-icon"><i class="bi bi-cart3"></i></span>
                            <h5 class="mb-0 fw-bold-700 text-dark">1. Sản phẩm trong giỏ hàng</h5>
                        </div>
                        <span class="badge bg-primary rounded-pill px-3 py-2">@Model.Count sản phẩm</span>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-sm align-middle cart-table mb-0" style="font-size: 0.85rem;">
                                <thead>
                                    <tr>
                                        <th class="ps-4">Sản Phẩm</th>
                                        <th class="text-end">Đơn Giá</th>
                                        <th class="text-center">Số Lượng</th>
                                        <th class="text-center">Giá</th>
                                        <th class="text-center pe-4">Xóa</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="d-flex align-items-center">
                                                    <div>
                                                        <h6 class="mb-0 fw-semibold-600 text-dark">@item.ProductName</h6>
                                                        <div class="mt-1 d-flex flex-wrap gap-1">
                                                            <span class="badge bg-light text-dark border small">Mã SP: #@item.ProductId</span>
                                                            <span class="badge bg-light text-dark border small">Còn lại: @item.AvailableQuantity.ToString("G29")</span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-end fw-semibold">@item.Price.ToString("N0") đ</td>
                                            <td class="text-center">
                                                <form action="/Cart/UpdateQuantity" method="post" class="quantity-form m-0">
                                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                                    <div class="quantity-control shadow-2xs">
                                                        <button type="button" class="btn-minus" onclick="changeQuantity(this, -1, @item.AvailableQuantity.ToString("G29"))">-</button>
                                                        <input type="number" name="quantity" class="quantity-input" value="@item.Quantity.ToString("G29")" min="1" max="@item.AvailableQuantity.ToString("G29")" step="1" onchange="submitQuantityForm(this, @item.AvailableQuantity.ToString("G29"))" required />
                                                        <button type="button" class="btn-plus" onclick="changeQuantity(this, 1, @item.AvailableQuantity.ToString("G29"))">+</button>
                                                    </div>
                                                </form>
                                            </td>
                                            <td class="text-end fw-bold text-dark">@item.TotalPrice.ToString("N0") đ</td>
                                            <td class="text-center pe-4">
                                                <form action="/Cart/RemoveItem" method="post" class="m-0 d-inline">
                                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                                    <button type="submit" class="btn btn-link  p-0 border-0" title="Xóa sản phẩm" onclick="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này khỏi giỏ hàng?')">
                                                        <i class="bi bi-trash3-fill fs-5"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card summary-card shadow-lg">
                    <div class="card-header summary-header">
                        <h5 class="mb-0 fw-bold-700 text-center text-uppercase tracking-wide"><i class="bi bi-receipt-cutoff me-2"></i>Tóm tắt đơn hàng</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Tổng tiền sản phẩm</span>
                            <span class="fw-bold text-dark fs-5">@totalAmount.ToString("N0") đ</span>
                        </div>
                        <div class="text-muted small mb-4">
                            <i class="bi bi-info-circle me-1"></i> Phí vận chuyển và các tùy chọn thanh toán cụ thể sẽ được áp dụng tại bước tiếp theo.
                        </div>
                        <hr class="my-3" style="border-top: 1px solid #e2e8f0;">

                        <a href="/Checkout" class="btn btn-gradient w-100 py-2.5 fw-bold-700 text-uppercase mb-3" style="font-size: 0.9rem;">
                            Tiến Hành Đặt Hàng <i class="bi bi-arrow-right-short ms-1 fs-5"></i>
                        </a>

                        <a href="/" class="btn btn-outline-gradient w-100 py-2 fw-semibold text-center text-decoration-none" style="font-size: 0.85rem;">
                            <i class="bi bi-arrow-left-short me-1 fs-5"></i> Tiếp tục mua sắm
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<script>
    function changeQuantity(btn, change, maxStock) {
        const form = btn.closest('form');
        const input = form.querySelector('.quantity-input');
        let currentVal = parseInt(input.value) || 0;
        let newVal = currentVal + change;

        if (newVal < 1) {
            newVal = 1;
        }
        if (newVal > maxStock) {
            alert(`Không thể đặt vượt quá số lượng tồn kho (${maxStock})!`);
            newVal = maxStock;
        }

        input.value = newVal;
        form.submit();
    }

    function submitQuantityForm(input, maxStock) {
        let val = parseInt(input.value) || 0;
        if (val < 1) {
            alert("Số lượng phải lớn hơn hoặc bằng 1!");
            input.value = 1;
            val = 1;
        }
        if (val > maxStock) {
            alert(`Không thể đặt vượt quá số lượng tồn kho (${maxStock})!`);
            input.value = maxStock;
            val = maxStock;
        }
        input.form.submit();
    }
</script>

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        --accent-color: #ff8c00;
        --accent-hover: #e07b00;
        --card-border-radius: 16px;
        --base-font-family: 'Plus Jakarta Sans', sans-serif;
        --bg-light-gray: #f8fafc;
        --text-dark: #0f172a;
        --text-muted: #64748b;
    }

    body {
        font-family: var(--base-font-family);
        background-color: var(--bg-light-gray);
        color: var(--text-dark);
    }

    .fw-bold-700 {
        font-weight: 700;
    }

    .fw-semibold-600 {
        font-weight: 600;
    }

    .checkout-stepper {
        display: flex;
        justify-content: space-between;
        position: relative;
        max-width: 600px;
        margin: 0 auto 2.5rem auto;
    }

        .checkout-stepper::before {
            content: "";
            position: absolute;
            top: 24px;
            left: 0;
            right: 0;
            height: 4px;
            background-color: #e2e8f0;
            z-index: 1;
        }

    .stepper-item {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        width: calc(100% / 3);
    }

    .stepper-circle {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background-color: #fff;
        border: 4px solid #e2e8f0;
        display: flex;
        justify-content: center;
        align-items: center;
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--text-muted);
        transition: all 0.3s ease;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    .stepper-item.active .stepper-circle {
        background: var(--primary-gradient);
        border-color: #fff;
        color: #fff;
        box-shadow: 0 10px 15px -3px rgba(30, 60, 114, 0.3);
    }

    .stepper-item.completed .stepper-circle {
        background-color: #10b981;
        border-color: #fff;
        color: #fff;
        box-shadow: 0 10px 15px -3px rgba(16, 185, 129, 0.3);
    }

    .stepper-text {
        margin-top: 0.5rem;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text-muted);
        transition: color 0.3s ease;
    }

    .stepper-item.active .stepper-text {
        color: #1e3c72;
    }

    .cart-card {
        border: none;
        border-radius: var(--card-border-radius);
        box-shadow: 0 4px 20px -2px rgba(15, 23, 42, 0.04);
        background-color: #ffffff;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .cart-card-header {
        border-bottom: 1px solid #f1f5f9;
        background-color: #ffffff;
        border-top-left-radius: var(--card-border-radius) !important;
        border-top-right-radius: var(--card-border-radius) !important;
        padding: 1.25rem 1.5rem;
    }

    .card-title-icon {
        background: var(--primary-gradient);
        color: #fff;
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        margin-right: 0.75rem;
    }

    .cart-table th {
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        color: var(--text-muted);
        border-bottom: 2px solid #f1f5f9;
        padding: 1rem 0.75rem;
    }

    .cart-table td {
        padding: 1.25rem 0.75rem;
        border-bottom: 1px solid #f1f5f9;
    }

    .summary-card {
        border: none;
        border-radius: var(--card-border-radius);
        box-shadow: 0 10px 30px -10px rgba(30, 60, 114, 0.15);
        background: #ffffff;
        overflow: hidden;
    }

    .summary-header {
        background: var(--primary-gradient);
        color: #ffffff;
        padding: 1.5rem;
        border-bottom: none;
    }

    .btn-gradient {
        background: var(--primary-gradient);
        border: none;
        color: #ffffff;
        font-weight: 700;
        letter-spacing: 0.5px;
        padding: 0.85rem;
        border-radius: 10px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(30, 60, 114, 0.2);
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

        .btn-gradient:hover {
            background: linear-gradient(135deg, #152b52 0%, #1e3c72 100%);
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(30, 60, 114, 0.3);
            color: #fff;
        }

    .btn-outline-gradient {
        border: 2px solid #1e3c72;
        background: transparent;
        color: #1e3c72;
        font-weight: 700;
        padding: 0.75rem 1.5rem;
        border-radius: 10px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
    }

        .btn-outline-gradient:hover {
            background: var(--primary-gradient);
            border-color: transparent;
            color: #ffffff;
        }

    .quantity-control {
        display: flex;
        align-items: center;
        justify-content: center;
        max-width: 140px;
        margin: 0 auto;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        overflow: hidden;
    }

        .quantity-control button {
            background: #f1f5f9;
            border: none;
            width: 35px;
            height: 35px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            transition: background 0.2s ease;
        }

            .quantity-control button:hover {
                background: #e2e8f0;
            }

        .quantity-control input {
            border: none;
            text-align: center;
            width: 50px;
            height: 35px;
            font-weight: 600;
            outline: none;
        }
</style>
